---
import '../styles/global.css';
import { site, navigation } from '../data/site';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = site.description, ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = new URL(currentPath, Astro.site);
const fullTitle = `${title} | CCRA`;
const ogImg = ogImage || new URL('/ccra/og-default.png', Astro.site).toString();

// Organization structured data
const orgSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Chemical Corps Regimental Association",
  "alternateName": "CCRA",
  "url": "https://waitholdthis.github.io/ccra/",
  "logo": "https://waitholdthis.github.io/ccra/brand/ccra-logo-text-111.jpg",
  "description": "Professional association supporting Dragon Soldiers and the U.S. Army Chemical Corps since 1986.",
  "foundingDate": "1986",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Fort Leonard Wood",
    "addressRegion": "MO",
    "addressCountry": "US"
  },
  "telephone": "+1-573-329-0600",
  "email": "ccramanager@embarqmail.com",
  "sameAs": []
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL.toString()} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL.toString()} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:site_name" content="Chemical Corps Regimental Association" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImg} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/ccra/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/ccra/favicon-32x32.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/ccra/apple-touch-icon.png" />
  <meta name="theme-color" content="#0a0a0f" />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={orgSchema} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ═══ NAVIGATION ═══ -->
  <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="flex items-center justify-between h-20">

        <!-- Logo -->
        <a href="/ccra/" class="flex items-center group" aria-label="Chemical Corps Regimental Association home">
          <img
            src="/ccra/brand/ccra-logo-text-111.jpg"
            width="342"
            height="111"
            alt="Chemical Corps Regimental Association Logo"
            class="h-12 w-auto rounded-sm bg-white p-1 opacity-95 shadow-[0_0_18px_rgba(0,0,0,0.55)] transition-opacity group-hover:opacity-100"
          />
        </a>

        <!-- Desktop Nav -->
        <div class="hidden lg:flex items-center gap-8">
          <a href="/ccra/" class={`nav-link ${currentPath === '/ccra/' ? 'active' : ''}`}>Home</a>
          <a href="/ccra/about" class={`nav-link ${currentPath === '/ccra/about/' || currentPath === '/ccra/about' ? 'active' : ''}`}>About</a>
          <a href="/ccra/history" class={`nav-link ${currentPath === '/ccra/history/' || currentPath === '/ccra/history' ? 'active' : ''}`}>History</a>
          <div class="nav-dropdown" style="position: relative;">
            <button class={`nav-link nav-dropdown-trigger ${currentPath.startsWith('/ccra/membership') || currentPath.startsWith('/ccra/chapters') ? 'active' : ''}`} style="background: none; border: none; cursor: pointer; display: flex; align-items: center; gap: 0.25rem; font: inherit; padding: 0;">
              Membership
              <svg style="width: 0.6rem; height: 0.6rem; margin-top: 1px; transition: transform 0.2s;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="nav-dropdown-menu" style="display: none; position: absolute; top: calc(100% + 0.75rem); left: 50%; transform: translateX(-50%); min-width: 180px; background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 6px; padding: 0.5rem 0; box-shadow: 0 8px 30px rgba(0,0,0,0.5); z-index: 60;">
              <a href="/ccra/membership" style="display: block; padding: 0.6rem 1.25rem; color: var(--color-bone); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; transition: all 0.2s; white-space: nowrap;" onmouseover="this.style.color='var(--color-dragon-gold)';this.style.background='rgba(197,163,85,0.06)'" onmouseout="this.style.color='var(--color-bone)';this.style.background='transparent'">Join / Renew</a>
              <a href="/ccra/chapters" style="display: block; padding: 0.6rem 1.25rem; color: var(--color-bone); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; transition: all 0.2s; white-space: nowrap;" onmouseover="this.style.color='var(--color-dragon-gold)';this.style.background='rgba(197,163,85,0.06)'" onmouseout="this.style.color='var(--color-bone)';this.style.background='transparent'">Local Chapters</a>
            </div>
          </div>
          <a href="/ccra/programs" class={`nav-link ${currentPath === '/ccra/programs/' || currentPath === '/ccra/programs' ? 'active' : ''}`}>Programs</a>
          <a href="/ccra/news" class={`nav-link ${currentPath === '/ccra/news/' || currentPath === '/ccra/news' ? 'active' : ''}`}>News</a>
          <a href="/ccra/giftshop" class={`nav-link ${currentPath === '/ccra/giftshop/' || currentPath === '/ccra/giftshop' ? 'active' : ''}`}>Gift Shop</a>
          <a href="/ccra/contact" class={`nav-link ${currentPath === '/ccra/contact/' || currentPath === '/ccra/contact' ? 'active' : ''}`}>Contact</a>
          <a href="/ccra/membership" class="btn-ghost text-[0.65rem] !py-2.5 !px-5">Join Now</a>
        </div>

        <!-- Mobile toggle -->
        <button id="mobile-toggle" class="lg:hidden text-[var(--color-bone)] p-2" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden hidden bg-[var(--color-void)] border-t border-[var(--color-steel)]">
      <div class="px-6 py-6 flex flex-col gap-4">
        <a href="/ccra/" class="nav-link">Home</a>
        <a href="/ccra/about" class="nav-link">About</a>
        <a href="/ccra/history" class="nav-link">History</a>
        <a href="/ccra/membership" class="nav-link">Membership</a>
        <a href="/ccra/chapters" class="nav-link" style="padding-left: 1rem; font-size: 0.8rem;">↳ Local Chapters</a>
        <a href="/ccra/programs" class="nav-link">Programs</a>
        <a href="/ccra/news" class="nav-link">News</a>
        <a href="/ccra/giftshop" class="nav-link">Gift Shop</a>
        <a href="/ccra/contact" class="nav-link">Contact</a>
        <a href="/ccra/membership" class="btn-solid text-center mt-2">Join Now</a>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <!-- ═══ FOOTER ═══ -->
  <footer class="bg-[var(--color-void)] border-t border-[var(--color-steel)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

        <!-- Brand -->
        <div>
          <div class="mb-4">
            <img
              src="/ccra/brand/ccra-logo-text-111.jpg"
              width="342"
              height="111"
              alt="Chemical Corps Regimental Association Logo"
              class="h-11 w-auto rounded-sm bg-white p-1 opacity-85"
            />
          </div>
          <p class="text-[var(--color-ash)] text-sm leading-relaxed">
            Promoting the heritage, history, esprit and professionalism of the United States Army Chemical Corps since 1986.
          </p>
          <p class="text-[var(--color-ash)] text-xs mt-4">
            501(c)(3) Nonprofit Corporation<br/>
            Donations are tax deductible
          </p>
        </div>

        <!-- Navigation -->
        <div>
          <h4 class="section-label mb-6">Navigate</h4>
          <div class="flex flex-col gap-3">
            <a href="/ccra/about" class="text-[var(--color-ash)] text-sm hover:text-[var(--color-dragon-gold)] transition-colors">About the CCRA</a>
            <a href="/ccra/history" class="text-[var(--color-ash)] text-sm hover:text-[var(--color-dragon-gold)] transition-colors">Corps History</a>
            <a href="/ccra/membership" class="text-[var(--color-ash)] text-sm hover:text-[var(--color-dragon-gold)] transition-colors">Membership</a>
            <a href="/ccra/chapters" class="text-[var(--color-ash)] text-sm hover:text-[var(--color-dragon-gold)] transition-colors">Local Chapters</a>
            <a href="/ccra/programs" class="text-[var(--color-ash)] text-sm hover:text-[var(--color-dragon-gold)] transition-colors">Programs & Scholarships</a>
            <a href="/ccra/news" class="text-[var(--color-ash)] text-sm hover:text-[var(--color-dragon-gold)] transition-colors">News & Events</a>
            <a href="/ccra/giftshop" class="text-[var(--color-ash)] text-sm hover:text-[var(--color-dragon-gold)] transition-colors">Gift Shop</a>
          </div>
        </div>

        <!-- Contact -->
        <div>
          <h4 class="section-label mb-6">Contact</h4>
          <div class="flex flex-col gap-3 text-sm text-[var(--color-ash)]">
            <div>
              <div class="text-[var(--color-bone)] font-medium">Headquarters</div>
              <div>495 S. Dakota Avenue, Bldg 1607</div>
              <div>Fort Leonard Wood, MO 65473</div>
            </div>
            <div>
              <div class="text-[var(--color-bone)] font-medium">Phone</div>
              <a href="tel:5733290600" class="hover:text-[var(--color-dragon-gold)] transition-colors">573.329.0600</a>
            </div>
            <div>
              <div class="text-[var(--color-bone)] font-medium">Email</div>
              <a href="mailto:ccramanager@embarqmail.com" class="hover:text-[var(--color-dragon-gold)] transition-colors">ccramanager@embarqmail.com</a>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div>
          <h4 class="section-label mb-6">Support the Corps</h4>
          <p class="text-[var(--color-ash)] text-sm mb-6">
            Your contributions support programs, scholarships, and the legacy of Dragon Soldiers and their families.
          </p>
          <a href="/ccra/membership" class="btn-solid text-center w-full block">Become a Member</a>
        </div>
      </div>

      <div class="gold-line mt-12 mb-8"></div>

      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-[var(--color-ash)]">
        <div>© {new Date().getFullYear()} {site.name}. All rights reserved.</div>
        <div class="flex items-center gap-2">
          <span>Heritage</span>
          <span class="text-[var(--color-dragon-gold)]">·</span>
          <span>Esprit de Corps</span>
          <span class="text-[var(--color-dragon-gold)]">·</span>
          <span>Image</span>
          <span class="text-[var(--color-dragon-gold)]">·</span>
          <span>Professionalism</span>
        </div>
      </div>
    </div>
  </footer>

  <script>
    // Nav scroll effect
    const nav = document.getElementById('main-nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 80) {
        if (nav) {
          nav.style.background = 'rgba(10,10,10,0.95)';
          nav.style.backdropFilter = 'blur(24px)';
          nav.style.WebkitBackdropFilter = 'blur(24px)';
          nav.style.borderBottom = '1px solid var(--color-steel)';
        }
      } else {
        if (nav) {
          nav.style.background = '';
          nav.style.backdropFilter = '';
          nav.style.WebkitBackdropFilter = '';
          nav.style.borderBottom = '';
        }
      }
    });

    // Mobile menu
    const toggle = document.getElementById('mobile-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle?.addEventListener('click', () => {
      menu?.classList.toggle('hidden');
    });

    // Fade-in on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    // Tab system
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const group = btn.closest('[data-tabs]');
        if (!group) return;
        group.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        group.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        const panel = group.querySelector(`#${btn.dataset.tab}`);
        panel?.classList.add('active');
      });
    });

    // Nav dropdown hover
    document.querySelectorAll('.nav-dropdown').forEach(dd => {
      const menu = dd.querySelector('.nav-dropdown-menu');
      const arrow = dd.querySelector('svg');
      let timeout;
      const show = () => { clearTimeout(timeout); menu.style.display = 'block'; if (arrow) arrow.style.transform = 'rotate(180deg)'; };
      const hide = () => { timeout = setTimeout(() => { menu.style.display = 'none'; if (arrow) arrow.style.transform = ''; }, 150); };
      dd.addEventListener('mouseenter', show);
      dd.addEventListener('mouseleave', hide);
      // Also handle click on trigger to go to membership page
      dd.querySelector('.nav-dropdown-trigger')?.addEventListener('click', () => {
        if (menu.style.display === 'block') return; // dropdown already open, let it be
        show();
      });
    });
  </script>

</body>
</html>
