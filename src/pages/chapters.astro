---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CCRA Chapters" description="Find a CCRA chapter near you. 16 chapters across the United States, Puerto Rico, and South Korea supporting Dragon Soldiers and the Chemical Corps community.">

  <!-- HERO -->
  <section style="background: var(--color-void); padding: 6rem 1.5rem 2rem; text-align: center;">
    <div style="max-width: 800px; margin: 0 auto;" class="fade-up">
      <p class="section-label" style="color: var(--color-dragon-gold); text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.875rem; margin-bottom: 0.75rem;">Local Chapters</p>
      <h1 class="section-title" style="color: var(--color-ivory); font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem;">CCRA Chapters</h1>
      <div class="gold-line" style="width: 80px; height: 3px; background: var(--color-dragon-gold); margin: 0 auto 1.5rem;"></div>
      <p style="color: var(--color-ash); font-size: 1.125rem; line-height: 1.7; max-width: 640px; margin: 0 auto;">
        16 chapters across the nation and overseas — connecting Dragon Soldiers, families, and supporters. Click a marker or chapter name to learn more.
      </p>
    </div>
  </section>

  <!-- MAP + LIST -->
  <section style="background: var(--color-bunker); padding: 2rem 1.5rem 5rem;">
    <div style="max-width: 1200px; margin: 0 auto;">

      <!-- MAP -->
      <div class="fade-up" style="margin-bottom: 2rem;">
        <div id="chapter-map" style="width: 100%; height: 520px; border-radius: 8px; border: 1px solid var(--color-gunmetal); overflow: hidden;"></div>
      </div>

      <!-- CHAPTER LIST + DETAIL PANEL -->
      <div id="chapters-container" style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;">

        <!-- CHAPTER LIST -->
        <div id="chapter-list" class="fade-up">
          <h2 style="color: var(--color-ivory); font-size: 1.25rem; font-weight: 700; margin-bottom: 1.25rem;">All Chapters</h2>
          <div id="chapter-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.75rem;">
            <!-- Filled by JS -->
          </div>
        </div>

        <!-- DETAIL PANEL (hidden by default) -->
        <div id="chapter-detail" style="display: none;">
          <button id="detail-close" style="background: none; border: 1px solid var(--color-gunmetal); color: var(--color-ash); padding: 0.5rem 1rem; border-radius: 4px; cursor: pointer; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1rem; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--color-dragon-gold)';this.style.color='var(--color-dragon-gold)'" onmouseout="this.style.borderColor='var(--color-gunmetal)';this.style.color='var(--color-ash)'">&larr; All Chapters</button>
          <div id="detail-content" style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 8px; padding: 2.5rem;">
            <!-- Filled by JS -->
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- START A CHAPTER -->
  <section style="background: var(--color-void); padding: 5rem 1.5rem;">
    <div style="max-width: 960px; margin: 0 auto;" class="fade-up">
      <div style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 8px; padding: 2.5rem;">
        <h2 style="color: var(--color-dragon-gold); font-size: 1.5rem; font-weight: 700; margin-bottom: 0.75rem;">Start a Local Chapter</h2>
        <div class="gold-line" style="width: 50px; height: 3px; background: var(--color-dragon-gold); margin-bottom: 1.25rem;"></div>
        <p style="color: var(--color-bone); line-height: 1.8; margin-bottom: 1rem;">
          Interested in starting a CCRA chapter in your area? Begin by reading the Chapter Constitution and Bylaws section of the Local Chapter Establishment Policy. Your local chapter will fall under Private Organization regulations if located on a military installation.
        </p>
        <p style="color: var(--color-bone); line-height: 1.8; margin-bottom: 1.5rem;">
          Approval must be obtained from the local Installation Commander. Once approved, send a formal request to the CCRA national office to obtain a Chapter Charter.
        </p>
        <div style="display: flex; flex-wrap: wrap; gap: 1rem; padding-top: 1rem; border-top: 1px solid var(--color-gunmetal);">
          <div>
            <span style="color: var(--color-dragon-gold); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;">Contact</span>
            <p style="color: var(--color-ivory); font-weight: 600; margin-top: 0.25rem;"><a href="tel:5733290600" style="color: var(--color-ivory); text-decoration: none;">(573) 329-0600</a></p>
          </div>
          <div>
            <span style="color: var(--color-dragon-gold); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;">Email</span>
            <p style="color: var(--color-ivory); font-weight: 600; margin-top: 0.25rem;"><a href="mailto:ccramanager@embarqmail.com" style="color: var(--color-ivory); text-decoration: none;">ccramanager@embarqmail.com</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Leaflet CSS/JS -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <style>
    /* Leaflet overrides for dark theme */
    #chapter-map .leaflet-control-zoom a {
      background: var(--color-command) !important;
      color: var(--color-dragon-gold) !important;
      border-color: var(--color-gunmetal) !important;
    }
    #chapter-map .leaflet-control-attribution {
      background: rgba(10,10,10,0.8) !important;
      color: var(--color-ash) !important;
      font-size: 0.6rem !important;
    }
    #chapter-map .leaflet-control-attribution a {
      color: var(--color-ash) !important;
    }
    .chapter-card {
      background: var(--color-command);
      border: 1px solid var(--color-gunmetal);
      border-radius: 6px;
      padding: 1rem 1.25rem;
      cursor: pointer;
      transition: all 0.25s ease;
      text-decoration: none;
      display: block;
    }
    .chapter-card:hover, .chapter-card.active {
      border-color: var(--color-dragon-gold);
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(197,163,85,0.08);
    }
    .chapter-card:hover .ch-name, .chapter-card.active .ch-name {
      color: var(--color-dragon-gold) !important;
    }
    .chapter-marker {
      background: transparent !important;
      border: none !important;
    }
    .marker-dot {
      width: 14px;
      height: 14px;
      background: var(--color-dragon-gold);
      border: 2px solid #fff;
      border-radius: 50%;
      box-shadow: 0 0 12px rgba(197,163,85,0.5), 0 0 24px rgba(197,163,85,0.2);
      cursor: pointer;
      transition: all 0.3s ease;
    }
    .marker-dot:hover, .marker-dot.active {
      transform: scale(1.4);
      box-shadow: 0 0 20px rgba(197,163,85,0.8), 0 0 40px rgba(197,163,85,0.4);
    }
    .marker-dot.overseas {
      background: #8bb4d9;
      box-shadow: 0 0 12px rgba(139,180,217,0.5);
    }
    .marker-dot.overseas:hover, .marker-dot.overseas.active {
      box-shadow: 0 0 20px rgba(139,180,217,0.8), 0 0 40px rgba(139,180,217,0.4);
    }
    .leaflet-popup-content-wrapper {
      background: var(--color-command) !important;
      border: 1px solid var(--color-gunmetal) !important;
      border-radius: 6px !important;
      color: var(--color-ivory) !important;
      box-shadow: 0 8px 30px rgba(0,0,0,0.5) !important;
    }
    .leaflet-popup-tip {
      background: var(--color-command) !important;
      border: 1px solid var(--color-gunmetal) !important;
      box-shadow: none !important;
    }
    .leaflet-popup-content {
      margin: 0.75rem 1rem !important;
      font-family: 'Inter', sans-serif !important;
    }
    @media (min-width: 768px) {
      #chapters-container {
        grid-template-columns: 1fr !important;
      }
    }
  </style>

