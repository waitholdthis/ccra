        phone: "(360) 539-8110",
        url: "https://www.ccrassn.org/jblm-chapter/"
      },
      {
        id: "spoehr", name: "LTG Thomas W. Spoehr Chapter", state: "Washington D.C.", city: "Washington, D.C.",
        lat: 38.91, lng: -77.04, overseas: false,
        president: "Mandy Lopez", established: "2008",
        description: "Formed to bring together people assigned to or living near Washington, D.C. Mission is to promote the Regiment, support deserving charities, and provide for professional development. Membership is open to all associated with the US Army Chemical Corps.",
        url: "https://www.ccrassn.org/ltg-thomas-w-spoehr-chapter/"
      }
    ];

    document.addEventListener('DOMContentLoaded', () => {
      // ── MAP SETUP ──
      const map = L.map('chapter-map', {
        center: [38.5, -96],
        zoom: 4,
        minZoom: 2,
        maxZoom: 10,
        zoomControl: true,
        scrollWheelZoom: true,
        attributionControl: true
      });

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> &copy; <a href="https://carto.com/">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 19
      }).addTo(map);

      const markers = {};

      chapters.forEach(ch => {
        const dot = L.divIcon({
          className: 'chapter-marker',
          html: `<div class="marker-dot ${ch.overseas ? 'overseas' : ''}" data-id="${ch.id}"></div>`,
          iconSize: [14, 14],
          iconAnchor: [7, 7]
        });

        const marker = L.marker([ch.lat, ch.lng], { icon: dot }).addTo(map);

        marker.bindPopup(`
          <div style="font-family: 'Inter', sans-serif;">
            <div style="font-weight: 700; color: #c5a355; font-size: 0.85rem; margin-bottom: 0.25rem;">${ch.name}</div>
            <div style="font-size: 0.75rem; color: #8a8a8a;">${ch.city}</div>
          </div>
        `, { closeButton: false, offset: [0, -4] });

        marker.on('click', () => showDetail(ch.id));
        marker.on('mouseover', function() { this.openPopup(); });
        marker.on('mouseout', function() { this.closePopup(); });

        markers[ch.id] = marker;
      });

      // ── CHAPTER LIST ──
      const grid = document.getElementById('chapter-grid');
      chapters.forEach(ch => {
        const card = document.createElement('div');
        card.className = 'chapter-card';
        card.dataset.id = ch.id;
        card.innerHTML = `
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div style="width: 8px; height: 8px; border-radius: 50; flex-shrink: 0; border-radius: 50%; background: ${ch.overseas ? '#8bb4d9' : '#c5a355'}; box-shadow: 0 0 8px ${ch.overseas ? 'rgba(139,180,217,0.4)' : 'rgba(197,163,85,0.4)'};"></div>
            <div>
              <div class="ch-name" style="color: var(--color-ivory); font-size: 0.9rem; font-weight: 600; line-height: 1.3;">${ch.name}</div>
              <div style="color: var(--color-ash); font-size: 0.75rem; margin-top: 0.15rem;">${ch.city}${ch.president ? ' · ' + ch.president : ''}</div>
            </div>
          </div>
        `;
        card.addEventListener('click', () => showDetail(ch.id));
        grid.appendChild(card);
      });

      // ── DETAIL PANEL ──
      const detailEl = document.getElementById('chapter-detail');
      const listEl = document.getElementById('chapter-list');
      const contentEl = document.getElementById('detail-content');
      const closeBtn = document.getElementById('detail-close');
      let activeId = null;

      closeBtn.addEventListener('click', () => {
        detailEl.style.display = 'none';
        listEl.style.display = 'block';
        document.querySelectorAll('.chapter-card').forEach(c => c.classList.remove('active'));
        document.querySelectorAll('.marker-dot').forEach(d => d.classList.remove('active'));
        activeId = null;
        // Reset map view
        map.setView([38.5, -96], 4, { animate: true });
      });

      function showDetail(id) {
        const ch = chapters.find(c => c.id === id);
        if (!ch) return;
        activeId = id;

        // Highlight card
        document.querySelectorAll('.chapter-card').forEach(c => c.classList.remove('active'));
        const card = document.querySelector(`.chapter-card[data-id="${id}"]`);
        if (card) card.classList.add('active');

        // Highlight marker
        document.querySelectorAll('.marker-dot').forEach(d => d.classList.remove('active'));
        const dot = document.querySelector(`.marker-dot[data-id="${id}"]`);
        if (dot) dot.classList.add('active');

        // Pan map
        map.setView([ch.lat, ch.lng], ch.overseas && ch.id === 'morningcalm' ? 5 : 7, { animate: true });

        // Build detail HTML
        let html = `
          <div style="margin-bottom: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
              <div style="width: 12px; height: 12px; border-radius: 50%; background: ${ch.overseas ? '#8bb4d9' : '#c5a355'}; box-shadow: 0 0 10px ${ch.overseas ? 'rgba(139,180,217,0.5)' : 'rgba(197,163,85,0.5)'};"></div>
              <span style="color: var(--color-ash); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em;">${ch.state}</span>
            </div>
            <h2 style="color: var(--color-dragon-gold); font-size: 1.5rem; font-weight: 700; margin-bottom: 0.25rem;">${ch.name}</h2>
            <p style="color: var(--color-ash); font-size: 0.85rem;">${ch.city}${ch.established ? ' · Est. ' + ch.established : ''}</p>
          </div>
          <div class="gold-line" style="width: 50px; height: 3px; background: var(--color-dragon-gold); margin-bottom: 1.5rem;"></div>
          <p style="color: var(--color-bone); line-height: 1.8; margin-bottom: 1.5rem;">${ch.description}</p>
        `;

        // President
        if (ch.president) {
          html += `
            <div style="margin-bottom: 1.25rem; padding: 1rem; background: rgba(197,163,85,0.05); border-left: 3px solid var(--color-dragon-gold); border-radius: 0 4px 4px 0;">
              <span style="color: var(--color-dragon-gold); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em;">Chapter President</span>
              <p style="color: var(--color-ivory); font-weight: 600; font-size: 1rem; margin-top: 0.25rem;">${ch.president}</p>
            </div>
          `;
        }

        // Board members
        if (ch.board) {
          html += `<div style="margin-bottom: 1.5rem;">
            <h3 style="color: var(--color-ivory); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;">Leadership</h3>
            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.5rem;">`;
          for (const [role, person] of Object.entries(ch.board)) {
            html += `<div style="padding: 0.5rem 0.75rem; background: rgba(255,255,255,0.02); border-radius: 4px;">
              <span style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em;">${role}</span>
              <p style="color: var(--color-bone); font-size: 0.85rem; margin-top: 0.15rem;">${person}</p>
            </div>`;
          }
          html += `</div></div>`;
        }

        // Purposes
        if (ch.purposes) {
          html += `<div style="margin-bottom: 1.5rem;">
            <h3 style="color: var(--color-ivory); font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;">Mission</h3>
            <ul style="list-style: none; padding: 0; margin: 0;">`;
          ch.purposes.forEach(p => {
            html += `<li style="color: var(--color-bone); padding: 0.35rem 0 0.35rem 1.25rem; position: relative; font-size: 0.9rem;">
              <span style="position: absolute; left: 0; color: var(--color-dragon-gold);">◆</span>${p}
            </li>`;
          });
          html += `</ul></div>`;
        }

        // Meeting info
        if (ch.meeting) {
          html += `<div style="margin-bottom: 1.25rem; padding: 1rem; background: rgba(197,163,85,0.05); border-left: 3px solid var(--color-dragon-gold); border-radius: 0 4px 4px 0;">
            <span style="color: var(--color-dragon-gold); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em;">Meetings</span>
            <p style="color: var(--color-bone); font-size: 0.9rem; margin-top: 0.25rem;">${ch.meeting}</p>
          </div>`;
        }

        // Contact info row
        let contactHtml = '';
        if (ch.address) contactHtml += `<div><span style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em;">Address</span><p style="color: var(--color-bone); font-size: 0.85rem; margin-top: 0.15rem;">${ch.address}</p></div>`;
        if (ch.email) contactHtml += `<div><span style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em;">Email</span><p style="color: var(--color-bone); font-size: 0.85rem; margin-top: 0.15rem;"><a href="mailto:${ch.email}" style="color: var(--color-dragon-gold); text-decoration: none;">${ch.email}</a></p></div>`;
        if (ch.phone) contactHtml += `<div><span style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.08em;">Phone</span><p style="color: var(--color-bone); font-size: 0.85rem; margin-top: 0.15rem;"><a href="tel:${ch.phone.replace(/[^\d+]/g, '')}" style="color: var(--color-dragon-gold); text-decoration: none;">${ch.phone}</a></p></div>`;
        if (contactHtml) {
          html += `<div style="display: flex; flex-wrap: wrap; gap: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--color-gunmetal); margin-top: 1.5rem;">${contactHtml}</div>`;
        }

        // Link to original site
        if (ch.url) {
          html += `<div style="margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--color-gunmetal);">
            <a href="${ch.url}" target="_blank" rel="noopener" style="color: var(--color-dragon-gold); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">
              Visit Chapter Page
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>`;
        }

        contentEl.innerHTML = html;
        listEl.style.display = 'none';
        detailEl.style.display = 'block';

        // Scroll to detail
        detailEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  </script>

</Layout>
