---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About the CCRA">

  <!-- ═══ HERO ═══ -->
  <section class="relative h-[60vh] min-h-[400px] flex items-center justify-center overflow-hidden">
    <div class="hero-overlay absolute inset-0 z-10"></div>
    <div class="absolute inset-0 bg-[var(--color-command)]">
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 30% 50%, var(--color-dragon-gold) 0%, transparent 60%);"></div>
    </div>
    <div class="relative z-20 text-center max-w-4xl mx-auto px-6">
      <p class="section-label mb-6 fade-up">Who We Are</p>
      <h1 class="section-title !text-[clamp(2.2rem,5vw,4rem)] !font-[200] mb-6 fade-up">About the CCRA</h1>
      <p class="text-[var(--color-ash)] text-lg md:text-xl leading-relaxed max-w-3xl mx-auto fade-up">
        Founded in 1986, the Chemical Corps Regimental Association promotes the heritage, history, esprit and professionalism of the United States Army Chemical Corps.
      </p>
    </div>
  </section>

  <!-- ═══ FOUNDING ═══ -->
  <section class="py-24 lg:py-32 bg-[var(--color-void)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

        <div class="fade-up">
          <p class="section-label mb-4">Our Origin</p>
          <h2 class="section-title mb-8">Founded to Serve<br/>Dragon Soldiers</h2>
          <div class="gold-line mb-8 max-w-[80px]" style="background: linear-gradient(90deg, var(--color-dragon-gold), transparent);"></div>
          <p class="text-[var(--color-bone)] text-base leading-relaxed mb-6">
            The Chemical Corps Regimental Association was founded in <span class="text-[var(--color-dragon-gold)] font-semibold">July 1986</span> by <span class="text-[var(--color-ivory)] font-medium">Major General Gerald Watson</span>, then Chief of the Chemical Corps and first Colonel of the Regiment.
          </p>
          <p class="text-[var(--color-ash)] text-base leading-relaxed">
            The CCRA replaced both the Chemical Corps Association and the Chemical Corps Museum Foundation, unifying the Corps community under a single organization dedicated to preserving its legacy and supporting its members.
          </p>
        </div>

        <div class="fade-up">
          <div class="card-dark rounded-sm p-10 lg:p-12">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-14 h-14 rounded-full border border-[var(--color-dragon-gold)] flex items-center justify-center bg-[rgba(197,163,85,0.08)]">
                <span class="text-[var(--color-dragon-gold)] text-2xl">☢</span>
              </div>
              <div>
                <div class="text-[var(--color-ivory)] font-semibold text-lg">MG Gerald Watson</div>
                <div class="text-[var(--color-ash)] text-sm">Founder & First Colonel of the Regiment</div>
              </div>
            </div>
            <blockquote class="text-[var(--color-bone)] text-base leading-relaxed italic border-l-2 border-[var(--color-dragon-gold)] pl-6">
              "The CCRA was established to unite all Chemical Corps Soldiers — past, present, and future — under one regimental family, ensuring our heritage and traditions endure."
            </blockquote>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ GOVERNANCE ═══ -->
  <section class="py-24 lg:py-32 bg-[var(--color-command)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="text-center max-w-3xl mx-auto mb-16 fade-up">
        <p class="section-label mb-4">Governance</p>
        <h2 class="section-title mb-6">Led by Those<br/>Who Have Served</h2>
        <div class="gold-line mx-auto max-w-[60px] mb-8"></div>
        <p class="text-[var(--color-ash)] text-base leading-relaxed">
          The CCRA is managed by a Board of Directors composed of active duty, retired, and veteran officers and NCOs who volunteer their time and expertise to serve the Chemical Corps community.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 fade-up">
        <div class="card-dark rounded-sm p-8 text-center">
          <div class="text-[var(--color-dragon-gold)] text-3xl mb-4">⚙</div>
          <h3 class="text-[var(--color-ivory)] font-semibold text-lg mb-3">Board of Directors</h3>
          <p class="text-[var(--color-ash)] text-sm leading-relaxed">
            Composed of active duty, retired, and veteran officers and NCOs who volunteer to guide the Association's mission and programs.
          </p>
        </div>
        <div class="card-dark rounded-sm p-8 text-center">
          <div class="text-[var(--color-dragon-gold)] text-3xl mb-4">📋</div>
          <h3 class="text-[var(--color-ivory)] font-semibold text-lg mb-3">Biannual Review</h3>
          <p class="text-[var(--color-ash)] text-sm leading-relaxed">
            The Board meets twice a year to review and approve plans, programs, and strategic initiatives that support Dragon Soldiers and their families.
          </p>
        </div>
        <div class="card-dark rounded-sm p-8 text-center">
          <div class="text-[var(--color-dragon-gold)] text-3xl mb-4">🤝</div>
          <h3 class="text-[var(--color-ivory)] font-semibold text-lg mb-3">Private Support</h3>
          <p class="text-[var(--color-ash)] text-sm leading-relaxed">
            The Association relies entirely on private contributions and the dedication of volunteers to fund its mission — no government funding.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ MISSION PILLARS ═══ -->
  <section class="py-24 lg:py-32 bg-[var(--color-void)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="text-center max-w-3xl mx-auto mb-16 fade-up">
        <p class="section-label mb-4">Our Mission</p>
        <h2 class="section-title mb-6">Four Pillars of<br/>the Chemical Corps</h2>
        <div class="gold-line mx-auto max-w-[60px] mb-8"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 fade-up">

        <!-- Heritage -->
        <div class="card-dark rounded-sm p-8 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[var(--color-dragon-gold)] to-transparent"></div>
          <div class="text-[var(--color-dragon-gold)] font-mono text-xs mb-4 tracking-widest">01</div>
          <h3 class="text-[var(--color-ivory)] font-semibold text-xl mb-4">Heritage</h3>
          <p class="text-[var(--color-ash)] text-sm leading-relaxed">
            Preserving and promoting the rich history of the Chemical Corps, from its establishment in 1918 to the modern-day Dragon Soldiers who carry its legacy forward.
          </p>
        </div>

        <!-- Esprit de Corps -->
        <div class="card-dark rounded-sm p-8 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[var(--color-dragon-gold)] to-transparent"></div>
          <div class="text-[var(--color-dragon-gold)] font-mono text-xs mb-4 tracking-widest">02</div>
          <h3 class="text-[var(--color-ivory)] font-semibold text-xl mb-4">Esprit de Corps</h3>
          <p class="text-[var(--color-ash)] text-sm leading-relaxed">
            Fostering unity, pride, and camaraderie among all Chemical Corps Soldiers — active duty, reserve, guard, retired, and veterans — as one regimental family.
          </p>
        </div>

        <!-- Image -->
        <div class="card-dark rounded-sm p-8 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[var(--color-dragon-gold)] to-transparent"></div>
          <div class="text-[var(--color-dragon-gold)] font-mono text-xs mb-4 tracking-widest">03</div>
          <h3 class="text-[var(--color-ivory)] font-semibold text-xl mb-4">Image</h3>
          <p class="text-[var(--color-ash)] text-sm leading-relaxed">
            Enhancing the public understanding and recognition of the Chemical Corps' vital role in defending the nation against chemical, biological, radiological, and nuclear threats.
          </p>
        </div>

        <!-- Professionalism -->
        <div class="card-dark rounded-sm p-8 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-[var(--color-dragon-gold)] to-transparent"></div>
          <div class="text-[var(--color-dragon-gold)] font-mono text-xs mb-4 tracking-widest">04</div>
          <h3 class="text-[var(--color-ivory)] font-semibold text-xl mb-4">Professionalism</h3>
          <p class="text-[var(--color-ash)] text-sm leading-relaxed">
            Advancing the technical and leadership competencies of Chemical Corps professionals through education, training support, and scholarship programs.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="py-20 lg:py-28 bg-[var(--color-command)] border-y border-[var(--color-steel)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 fade-up">

        <div class="text-center">
          <div class="text-[var(--color-dragon-gold)] text-4xl lg:text-5xl font-[200] mb-2">6,915</div>
          <div class="text-[var(--color-ash)] text-xs tracking-[3px] uppercase">Lifetime Members</div>
        </div>

        <div class="text-center">
          <div class="text-[var(--color-dragon-gold)] text-4xl lg:text-5xl font-[200] mb-2">16</div>
          <div class="text-[var(--color-ash)] text-xs tracking-[3px] uppercase">Chapters</div>
        </div>

        <div class="text-center">
          <div class="text-[var(--color-dragon-gold)] text-4xl lg:text-5xl font-[200] mb-2">$31K+</div>
          <div class="text-[var(--color-ash)] text-xs tracking-[3px] uppercase">2025 Scholarships</div>
        </div>

        <div class="text-center">
          <div class="text-[var(--color-dragon-gold)] text-4xl lg:text-5xl font-[200] mb-2">1986</div>
          <div class="text-[var(--color-ash)] text-xs tracking-[3px] uppercase">Founded</div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ CONTACT ═══ -->
  <section class="py-24 lg:py-32 bg-[var(--color-void)]">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <div class="fade-up">
          <p class="section-label mb-4">Headquarters</p>
          <h2 class="section-title mb-8">Get in Touch</h2>
          <div class="gold-line mb-8 max-w-[80px]" style="background: linear-gradient(90deg, var(--color-dragon-gold), transparent);"></div>

          <div class="space-y-6">
            <div>
              <div class="text-[var(--color-ivory)] font-medium text-sm tracking-wider uppercase mb-2">Address</div>
              <p class="text-[var(--color-bone)] text-base leading-relaxed">
                495 S. Dakota Avenue, Bldg 1607<br/>
                Fort Leonard Wood, MO 65473
              </p>
            </div>

            <div>
              <div class="text-[var(--color-ivory)] font-medium text-sm tracking-wider uppercase mb-2">Phone</div>
              <a href="tel:5733290600" class="text-[var(--color-bone)] text-base hover:text-[var(--color-dragon-gold)] transition-colors">
                573.329.0600
              </a>
            </div>

            <div>
              <div class="text-[var(--color-ivory)] font-medium text-sm tracking-wider uppercase mb-2">Email</div>
              <a href="mailto:ccramanager@embarqmail.com" class="text-[var(--color-bone)] text-base hover:text-[var(--color-dragon-gold)] transition-colors">
                ccramanager@embarqmail.com
              </a>
            </div>

            <div class="pt-4">
              <div class="inline-flex items-center gap-3 card-dark rounded-sm px-5 py-3">
                <span class="text-[var(--color-dragon-gold)] text-sm">✦</span>
                <span class="text-[var(--color-ash)] text-sm">501(c)(3) Nonprofit Corporation — Donations are tax deductible</span>
              </div>
            </div>
          </div>
        </div>

        <div class="fade-up">
          <div class="card-dark rounded-sm p-10 lg:p-12">
            <h3 class="text-[var(--color-ivory)] font-semibold text-xl mb-4">Ready to Join the Family?</h3>
            <p class="text-[var(--color-ash)] text-base leading-relaxed mb-8">
              Whether you're active duty, retired, or a veteran of the Chemical Corps, the CCRA welcomes you. Become a lifetime member and support the Dragon Soldier legacy.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/ccra/membership" class="btn-solid justify-center">Become a Member</a>
              <a href="/ccra/contact" class="btn-ghost justify-center">Contact Us</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>
