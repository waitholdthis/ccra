---
import Layout from '../layouts/Layout.astro';
import partners from '../data/partners.json';

const assetBase = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const partnerAsset = (src: string) => `${assetBase}${src}`;
---

<Layout title="CCRA — Dragon Soldiers | Chemical Corps Regimental Association">

  <!-- ═══════════════════════════════════════════════════════════════════
       HERO — 100vh cinematic entrance
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden" style="background: #000;">

    <!-- Fullscreen video background -->
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
      style="z-index: 0;"
    >
      <source src="/ccra/Dragon_Crest.mp4" type="video/mp4" />
    </video>

    <!-- Cinematic overlay: dark vignette + subtle gradient to keep text readable -->
    <div class="absolute inset-0" style="z-index: 1; background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.35) 40%, rgba(0,0,0,0.55) 75%, rgba(0,0,0,0.85) 100%);"></div>
    <!-- Subtle radial vignette for depth -->
    <div class="absolute inset-0" style="z-index: 2; background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.6) 100%);"></div>

    <div class="relative text-center max-w-5xl mx-auto px-6 lg:px-12" style="z-index: 10;">
      <div class="gold-line mx-auto mb-8" style="width: 80px;"></div>
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-black tracking-widest uppercase mb-4" style="color: var(--color-dragon-gold); text-shadow: 0 0 60px rgba(191,163,80,0.3);">
        DRAGON SOLDIERS
      </h1>
      <p class="text-xl md:text-2xl tracking-[0.25em] uppercase mb-4" style="color: var(--color-bone);">
        Chemical Corps Regimental Association
      </p>
      <p class="text-sm md:text-base tracking-[0.3em] uppercase mb-12" style="color: #c9a84c;">
        Heritage · Esprit de Corps · Image · Professionalism
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-20">
        <a href="/ccra/membership" class="btn-solid">Become a Member</a>
        <a href="/ccra/history" class="btn-ghost">Our History</a>
      </div>
    </div>

    <!-- Stat counters -->
    <div class="relative w-full border-t" style="z-index: 10; border-color: rgba(191,163,80,0.15);">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-8 grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div class="hero-stat" data-target="6915">
          <span class="stat-number text-4xl md:text-5xl font-black" style="color: var(--color-dragon-gold);">6,915</span>
          <span class="block text-xs tracking-[0.3em] uppercase mt-2" style="color: var(--color-ivory);">Lifetime Members</span>
        </div>
        <div class="hero-stat" data-target="16">
          <span class="stat-number text-4xl md:text-5xl font-black" style="color: var(--color-dragon-gold);">16</span>
          <span class="block text-xs tracking-[0.3em] uppercase mt-2" style="color: var(--color-ivory);">Chapters</span>
        </div>
        <div class="hero-stat" data-target="31000">
          <span class="stat-number text-4xl md:text-5xl font-black" style="color: var(--color-dragon-gold);">$31,000+</span>
          <span class="block text-xs tracking-[0.3em] uppercase mt-2" style="color: var(--color-ivory);">in 2025 Scholarships</span>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       PURPOSE
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32" style="background-color: var(--color-void);">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 fade-up">
      <div class="text-center max-w-4xl mx-auto">
        <span class="section-label">Who We Are</span>
        <h2 class="section-title">Our Purpose</h2>
        <div class="gold-line mx-auto mb-8"></div>
        <p class="text-lg md:text-xl leading-relaxed" style="color: var(--color-bone);">
          The purpose of the Association is to promote the heritage, history, esprit and professionalism of the United States Army Chemical Corps, and advance scientific, literary, educational, and artistic endeavors of the Chemical Corps.
        </p>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       PILLARS — 4 cards
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32" style="background-color: var(--color-bunker);">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="text-center mb-16 fade-up">
        <span class="section-label">What We Do</span>
        <h2 class="section-title">Our Pillars</h2>
        <div class="gold-line mx-auto"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 fade-up">
        <!-- Programs -->
        <div class="card-dark text-center" style="display:flex; flex-direction:column;">
          <div class="text-5xl mb-6">☢</div>
          <h3 class="text-xl font-bold uppercase tracking-wider mb-3" style="color: var(--color-dragon-gold);">Programs</h3>
          <p class="text-sm leading-relaxed mb-6" style="color: var(--color-bone);">Scholarships, awards, and initiatives that strengthen the Chemical Corps community and support our Dragon Soldiers.</p>
          <a href="/ccra/programs" class="btn-ghost text-sm" style="justify-content:center; width:100%; margin-top:auto;">Explore Programs</a>
        </div>

        <!-- Membership -->
        <div class="card-dark text-center" style="display:flex; flex-direction:column;">
          <div class="text-5xl mb-6">⚔</div>
          <h3 class="text-xl font-bold uppercase tracking-wider mb-3" style="color: var(--color-dragon-gold);">Membership</h3>
          <p class="text-sm leading-relaxed mb-6" style="color: var(--color-bone);">Join thousands of active duty, reserve, retired, and veteran Chemical Corps professionals united in service.</p>
          <a href="/ccra/membership" class="btn-ghost text-sm" style="justify-content:center; width:100%; margin-top:auto;">Join Now</a>
        </div>

        <!-- History -->
        <div class="card-dark text-center" style="display:flex; flex-direction:column;">
          <div class="text-5xl mb-6">📜</div>
          <h3 class="text-xl font-bold uppercase tracking-wider mb-3" style="color: var(--color-dragon-gold);">History</h3>
          <p class="text-sm leading-relaxed mb-6" style="color: var(--color-bone);">Over a century of service — from World War I to modern CBRN defense. Explore the legacy of the Chemical Corps.</p>
          <a href="/ccra/history" class="btn-ghost text-sm" style="justify-content:center; width:100%; margin-top:auto;">Our Heritage</a>
        </div>

        <!-- News -->
        <div class="card-dark text-center" style="display:flex; flex-direction:column;">
          <div class="text-5xl mb-6">📰</div>
          <h3 class="text-xl font-bold uppercase tracking-wider mb-3" style="color: var(--color-dragon-gold);">News</h3>
          <p class="text-sm leading-relaxed mb-6" style="color: var(--color-bone);">Stay current with the latest CCRA news, Dragon Fire newsletter, event recaps, and Corps updates.</p>
          <a href="/ccra/news" class="btn-ghost text-sm" style="justify-content:center; width:100%; margin-top:auto;">Latest News</a>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       EVENTS — 2026 Regimental Week
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32" style="background-color: var(--color-void);">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="text-center mb-16 fade-up">
        <span class="section-label">Mark Your Calendar</span>
        <h2 class="section-title">2026 Regimental Week</h2>
        <div class="gold-line mx-auto"></div>
      </div>

      <div class="max-w-3xl mx-auto space-y-4 fade-up">
        <!-- Event 1 -->
        <div class="flex items-start gap-6 p-6 rounded-sm border" style="background: rgba(191,163,80,0.03); border-color: rgba(191,163,80,0.1);">
          <div class="shrink-0 text-center" style="min-width: 60px;">
            <span class="block text-xs uppercase tracking-widest" style="color: var(--color-bone);">Jun</span>
            <span class="block text-3xl font-black" style="color: var(--color-dragon-gold);">2</span>
          </div>
          <div>
            <h4 class="font-bold text-base mb-1" style="color: var(--color-bone);">CBRN 2026 Regimental Week Golf Tournament</h4>
            <span class="text-sm" style="color: var(--color-bone);">12:30 – 5:00 pm</span>
          </div>
        </div>

        <!-- Event 2 -->
        <div class="flex items-start gap-6 p-6 rounded-sm border" style="background: rgba(191,163,80,0.03); border-color: rgba(191,163,80,0.1);">
          <div class="shrink-0 text-center" style="min-width: 60px;">
            <span class="block text-xs uppercase tracking-widest" style="color: var(--color-bone);">Jun</span>
            <span class="block text-3xl font-black" style="color: var(--color-dragon-gold);">2</span>
          </div>
          <div>
            <h4 class="font-bold text-base mb-1" style="color: var(--color-bone);">2026 Commandant's Regimental Week Social</h4>
            <span class="text-sm" style="color: var(--color-bone);">5:00 – 7:00 pm</span>
          </div>
        </div>

        <!-- Event 3 -->
        <div class="flex items-start gap-6 p-6 rounded-sm border" style="background: rgba(191,163,80,0.03); border-color: rgba(191,163,80,0.1);">
          <div class="shrink-0 text-center" style="min-width: 60px;">
            <span class="block text-xs uppercase tracking-widest" style="color: var(--color-bone);">Jun</span>
            <span class="block text-3xl font-black" style="color: var(--color-dragon-gold);">3</span>
          </div>
          <div>
            <h4 class="font-bold text-base mb-1" style="color: var(--color-bone);">US Army Chemical Corps 2026 Regimental Run</h4>
            <span class="text-sm" style="color: var(--color-bone);">6:00 – 7:30 am</span>
          </div>
        </div>

        <!-- Event 4 -->
        <div class="flex items-start gap-6 p-6 rounded-sm border" style="background: rgba(191,163,80,0.03); border-color: rgba(191,163,80,0.1);">
          <div class="shrink-0 text-center" style="min-width: 60px;">
            <span class="block text-xs uppercase tracking-widest" style="color: var(--color-bone);">Jun</span>
            <span class="block text-3xl font-black" style="color: var(--color-dragon-gold);">3</span>
          </div>
          <div>
            <h4 class="font-bold text-base mb-1" style="color: var(--color-bone);">Regimental Week Annual Social Meeting</h4>
            <span class="text-sm" style="color: var(--color-bone);">5:00 – 7:00 pm</span>
          </div>
        </div>

        <!-- Event 5 -->
        <div class="flex items-start gap-6 p-6 rounded-sm border" style="background: rgba(191,163,80,0.03); border-color: rgba(191,163,80,0.1);">
          <div class="shrink-0 text-center" style="min-width: 60px;">
            <span class="block text-xs uppercase tracking-widest" style="color: var(--color-bone);">Jun</span>
            <span class="block text-3xl font-black" style="color: var(--color-dragon-gold);">3</span>
          </div>
          <div>
            <h4 class="font-bold text-base mb-1" style="color: var(--color-bone);">2026 Regimental Week Regimental CSM's Social</h4>
            <span class="text-sm" style="color: var(--color-bone);">6:00 – 8:00 pm</span>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       UPCOMING EVENTS (live from ccrassn.org)
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32" style="background-color: var(--color-command);">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="text-center mb-14 fade-up">
        <span class="section-label">Upcoming Events</span>
        <h2 class="section-title">Events</h2>
        <div class="gold-line mx-auto mt-6"></div>
      </div>

      <div id="events-list" class="max-w-3xl mx-auto space-y-4 fade-up">
        <!-- Loading state -->
        <div id="events-loading" style="text-align:center; padding: 2rem; color: var(--color-ash); font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase;">
          Loading events...
        </div>
      </div>

      <div class="text-center mt-10 fade-up">
        <a href="https://www.ccrassn.org/events/" target="_blank" rel="noopener noreferrer" class="btn-ghost" style="display:inline-flex; align-items:center; gap:0.5rem;">
          View All Events
          <svg style="width:0.85rem;height:0.85rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       BEST CBRN WARRIOR SUPPORTERS + CORPORATE MEMBERS
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32" style="background-color: var(--color-bunker);">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="text-center mb-14 fade-up">
        <span class="section-label">Our Partners</span>
        <h2 class="section-title">2026 Best CBRN Warrior Supporters</h2>
        <p class="mt-6 max-w-3xl mx-auto text-sm md:text-base leading-relaxed" style="color: var(--color-bone);">
          A very special thanks to the supporters of the 2026 Best CBRN Warrior Competition.
        </p>
        <div class="gold-line mx-auto mt-8"></div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-7 gap-4 mb-24 fade-up">
        {partners.supporters.map((partner) => (
          <figure class="partner-card supporter-card" title={partner.name}>
            <img
              class="partner-logo"
              src={partnerAsset(partner.src)}
              alt={`${partner.name} logo`}
              loading="lazy"
              decoding="async"
            />
            <figcaption>{partner.name}</figcaption>
          </figure>
        ))}
      </div>

      <!-- Welcome: Newest Learning Partner -->
      <div class="fade-up" style="margin-bottom: 3rem; padding: 2rem 2.5rem; background: var(--color-command); border: 1px solid var(--color-gunmetal); border-left: 4px solid var(--color-dragon-gold); border-radius: 6px; display: flex; flex-wrap: wrap; align-items: center; gap: 2rem;">
        <img
          src="/ccra/partners/columbia-southern-university.jpg"
          alt="Columbia Southern University"
          style="height: 70px; width: auto; object-fit: contain; flex-shrink: 0;"
        />
        <div style="flex: 1; min-width: 240px;">
          <p style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.4rem;">Welcome — Newest Member &amp; Learning Partner</p>
          <h3 style="color: var(--color-ivory); font-size: 1.2rem; font-weight: 700; margin-bottom: 0.4rem;">Columbia Southern University</h3>
          <p style="color: var(--color-bone); font-size: 0.9rem; line-height: 1.6;">The CCRA proudly welcomes Columbia Southern University as our newest corporate member and official learning partner — offering flexible, affordable online education for Dragon Soldiers and their families.</p>
        </div>
        <a href="/ccra/programs#learning-partner" style="flex-shrink: 0; display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.6rem 1.25rem; background: rgba(197,163,85,0.1); border: 1px solid var(--color-dragon-gold); border-radius: 2px; color: var(--color-dragon-gold); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='rgba(197,163,85,0.2)'" onmouseout="this.style.background='rgba(197,163,85,0.1)'">
          Learn More
          <svg style="width:0.75rem;height:0.75rem;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>

      <div class="text-center mb-16 fade-up">
        <span class="section-label">Corporate Members</span>
        <h2 class="section-title">Thank You to Our Corporate Members</h2>
        <div class="gold-line mx-auto"></div>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 fade-up">
        {partners.corporate.map((partner) => (
          <figure class="partner-card corporate-card" title={partner.name}>
            <img
              class="partner-logo"
              src={partnerAsset(partner.src)}
              alt={`${partner.name} logo`}
              loading="lazy"
              decoding="async"
            />
            <figcaption>{partner.name}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       FINAL CTA
       ═══════════════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32 text-center" style="background: linear-gradient(180deg, var(--color-void) 0%, #0a0c06 50%, var(--color-void) 100%);">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 fade-up">
      <div class="gold-line mx-auto mb-8"></div>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-wider mb-6" style="color: var(--color-dragon-gold); text-shadow: 0 0 40px rgba(191,163,80,0.2);">
        Join the Dragon Soldiers
      </h2>
      <p class="text-lg mb-10 max-w-2xl mx-auto" style="color: var(--color-bone);">
        Stand with thousands of Chemical Corps professionals past, present, and future.
      </p>
      <a href="/ccra/membership" class="btn-solid text-lg px-10 py-4">Become a Member</a>
    </div>
  </section>

</Layout>

<script>
  // Live events from ccrassn.org API
  async function loadEvents() {
    const list = document.getElementById('events-list');
    const loading = document.getElementById('events-loading');
    try {
      const res = await fetch('https://www.ccrassn.org/wp-json/tribe/events/v1/events?per_page=10&status=publish', {
        headers: { 'Accept': 'application/json' }
      });
      if (!res.ok) throw new Error('fetch failed');
      const data = await res.json();
      const events = Array.isArray(data) ? data : (data.events || []);
      if (loading) loading.remove();

      if (!events.length) {
        list!.innerHTML = '<p style="text-align:center;color:var(--color-ash);font-size:0.9rem;">No upcoming events found.</p>';
        return;
      }

      const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
      events.forEach((ev: any) => {
        const start = new Date(ev.start_date);
        const end = new Date(ev.end_date);
        const mon = months[start.getMonth()];
        const day = start.getDate();
        const venue = ev.venue ? [ev.venue.venue, ev.venue.city, ev.venue.stateprovince].filter(Boolean).join(', ') : '';
        const timeStr = start.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) +
          (end.getTime() !== start.getTime() ? ' – ' + end.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) : '');

        const card = document.createElement('a');
        card.href = ev.url || 'https://www.ccrassn.org/events/';
        card.target = '_blank';
        card.rel = 'noopener noreferrer';
        card.style.cssText = 'display:flex; align-items:flex-start; gap:1.5rem; padding:1.5rem; border-radius:2px; border:1px solid rgba(191,163,80,0.15); background:rgba(191,163,80,0.03); text-decoration:none; transition:border-color 0.2s, background 0.2s;';
        card.onmouseenter = () => { card.style.borderColor = 'rgba(191,163,80,0.4)'; card.style.background = 'rgba(191,163,80,0.06)'; };
        card.onmouseleave = () => { card.style.borderColor = 'rgba(191,163,80,0.15)'; card.style.background = 'rgba(191,163,80,0.03)'; };

        card.innerHTML = `
          <div style="flex-shrink:0;width:64px;height:64px;display:flex;flex-direction:column;align-items:center;justify-content:center;border:1px solid var(--color-dragon-gold);background:rgba(197,163,85,0.06);">
            <span style="color:var(--color-dragon-gold);font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;">${mon}</span>
            <span style="color:var(--color-ivory);font-size:1.6rem;font-weight:900;line-height:1;">${day}</span>
          </div>
          <div style="flex:1;">
            <h3 style="color:var(--color-ivory);font-weight:600;font-size:1rem;margin-bottom:0.3rem;">${ev.title}</h3>
            <p style="color:var(--color-bone);font-size:0.85rem;margin:0;">${timeStr}${venue ? ' &nbsp;·&nbsp; ' + venue : ''}</p>
          </div>
          <svg style="flex-shrink:0;width:1rem;height:1rem;color:var(--color-dragon-gold);align-self:center;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        `;
        list!.appendChild(card);
      });
    } catch {
      if (loading) loading.textContent = 'Unable to load events. Visit ccrassn.org/events for the latest.';
    }
  }
  loadEvents();

  // Intersection Observer for fade-up animations
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.fade-up').forEach((el) => observer.observe(el));

  // Stat counter animation
  function animateCounters() {
    const stats = document.querySelectorAll('.hero-stat');
    stats.forEach((stat) => {
      const numberEl = stat.querySelector('.stat-number');
      if (!numberEl) return;
      const text = numberEl.textContent || '';
      const target = parseInt(stat.getAttribute('data-target') || '0', 10);
      if (target === 0) return;

      const prefix = text.startsWith('$') ? '$' : '';
      const suffix = text.includes('+') ? '+' : '';
      const duration = 2000;
      const start = performance.now();

      function update(now: number) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.floor(eased * target);
        if (numberEl) {
          numberEl.textContent = prefix + current.toLocaleString() + suffix;
        }
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    });
  }

  // Trigger counters when hero stats are visible
  const heroObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        animateCounters();
        heroObserver.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const statsRow = document.querySelector('.hero-stat');
  if (statsRow) heroObserver.observe(statsRow);
</script>
