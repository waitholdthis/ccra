const roleColors = {
  sma:            { bg: '#0d1a2e', border: '#2a5aaa', text: '#7ab8ee', label: 'Senior Military Advisor', dot: '#3a7acc' },
  board:          { bg: '#2a1f00', border: '#c9a84c', text: '#c9a84c', label: 'Board of Directors',       dot: '#c9a84c' },
  officer:        { bg: '#2a1400', border: '#d07830', text: '#f0a060', label: 'Officers',                 dot: '#e08840' },
  employee:       { bg: '#1a1a1a', border: '#5a5a5a', text: '#aaaaaa', label: 'Employees',                dot: '#7a7a7a' },
  chapter:        { bg: '#0f1f0f', border: '#2a6a2a', text: '#7acd7a', label: 'Chapters (Current)',       dot: '#3a8a3a' },
