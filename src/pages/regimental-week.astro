---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Regimental Week | CCRA">

  <!-- HERO -->
  <section style="position: relative; min-height: 520px; display: flex; align-items: center; justify-content: center; text-align: center; overflow: hidden; padding: 6rem 1.5rem 4rem;">
    <!-- Background image -->
    <div style="position: absolute; inset: 0; background: url('/ccra/regimental-week/Hero_Background.png') center center / cover no-repeat;"></div>
    <!-- Dark overlay -->
    <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.55);"></div>
    <!-- Gold bottom bar -->
    <div style="position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, transparent, var(--color-dragon-gold), transparent);"></div>

    <div style="position: relative; z-index: 1; max-width: 800px; margin: 0 auto;" class="fade-up">
      <p class="section-label" style="color: var(--color-dragon-gold); text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.875rem; margin-bottom: 0.75rem;">Annual Tradition</p>
      <h1 class="section-title" style="color: var(--color-ivory); font-size: 3rem; font-weight: 700; margin-bottom: 1rem;">Regimental Week</h1>
      <div class="gold-line" style="width: 80px; height: 3px; background: var(--color-dragon-gold); margin: 0 auto 1.5rem;"></div>
      <p style="color: var(--color-ash); font-size: 1.125rem; line-height: 1.7; max-width: 640px; margin: 0 auto;">
        The Chemical Corps Regimental Association's annual celebration of heritage, camaraderie, and service — uniting Dragon Soldiers past and present.
      </p>
    </div>
  </section>

  <!-- 2026 BEST CBRN WARRIOR COMPETITION -->
  <section style="background: var(--color-bunker); padding: 5rem 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto;" class="fade-up">

      <div style="text-align: center; margin-bottom: 2.5rem;">
        <p class="section-label" style="color: var(--color-dragon-gold); text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.7rem; margin-bottom: 0.75rem;">2026 Regimental Week</p>
        <h2 class="section-title" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; margin-bottom: 1rem;">Best CBRN Warrior Competition</h2>
        <div class="gold-line" style="width: 60px; margin: 0 auto;"></div>
      </div>

      <!-- Photo -->
      <div style="border: 1px solid var(--color-gunmetal); border-radius: 6px; overflow: hidden; box-shadow: 0 0 40px rgba(0,0,0,0.5); margin-bottom: 2.5rem; max-width: 600px; margin-left: auto; margin-right: auto;">
        <img
          src="/ccra/regimental-week/2026_Winners.jpg"
          alt="2026 Best CBRN Warrior Competition Winners — SSgt Luke Litwaitis and TSgt Robert Sherwood"
          style="width: 100%; display: block; object-fit: cover;"
        />
        <div style="position: relative; height: 3px; background: linear-gradient(90deg, transparent, var(--color-dragon-gold), transparent); margin-top: -3px;"></div>
      </div>

      <!-- Congratulations card -->
      <div style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-left: 4px solid var(--color-dragon-gold); border-radius: 6px; padding: 2.5rem;">
        <div style="margin-bottom: 1.25rem;">
          <h3 style="color: var(--color-dragon-gold); font-size: 1.25rem; font-weight: 700; margin: 0;">Congratulations to the 2026 Winners!</h3>
        </div>
        <p style="color: var(--color-bone); font-size: 1.05rem; line-height: 1.85; margin-bottom: 1.25rem;">
          A huge congratulations to the Airmen of the <strong style="color: var(--color-ivory);">368th Training Squadron — United States Air Force</strong>, Team #5,
          <strong style="color: var(--color-ivory);">SSgt Luke Litwaitis</strong> and <strong style="color: var(--color-ivory);">TSgt Robert Sherwood</strong>,
          <strong style="color: var(--color-dragon-gold);">THE winners of the 2026 Best CBRN Warrior Competition!</strong>
        </p>
        <p style="color: var(--color-bone); font-size: 1.05rem; line-height: 1.85; margin-bottom: 1.25rem;">
          We hope you enjoy the amazing 1st place prizes presented on behalf of <em style="color: var(--color-ivory);">"Your Profession's Professional Association"</em>.
        </p>
        <p style="color: var(--color-ash); font-size: 1rem; line-height: 1.85;">
          Now if you could swing by the museum when you get a chance — the CCRA would like to discuss your membership status.
        </p>
      </div>

      <!-- See All The Fun button -->
      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/ccra/regimental-week-gallery" class="btn-solid" style="display: inline-flex; align-items: center; gap: 0.6rem; font-size: 1rem; padding: 0.9rem 2.5rem; font-weight: 700; text-decoration: none; background: var(--color-dragon-gold); color: var(--color-void); border-radius: 4px; text-transform: uppercase; letter-spacing: 0.1em; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">
          <svg style="width:1.1rem;height:1.1rem;flex-shrink:0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          See All The Fun!
        </a>
      </div>

    </div>
  </section>

</Layout>
