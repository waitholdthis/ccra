---
import Layout from '../layouts/Layout.astro';

const documents = [
  {
    title: 'By-Laws',
    description: 'The official by-laws governing the Chemical Corps Regimental Association.',
    url: 'https://acrobat.adobe.com/id/urn:aaid:sc:US:a375da64-b15b-4988-9167-6667c21fefd3',
  },
  {
    title: 'Constitution',
    description: 'The governing constitution of the Chemical Corps Regimental Association.',
    url: 'https://www.ccrassn.org/wp-content/uploads/2018/02/ccraconstitution2014oct.pdf',
  },
  {
    title: 'Executive Committee Charter',
    description: 'Charter defining the structure and responsibilities of the CCRA Executive Committee.',
    url: 'https://www.ccrassn.org/wp-content/uploads/2018/02/ccra_executive_committee_charter.pdf',
  },
  {
    title: 'Chapter Establishment',
    description: 'Guidelines and procedures for establishing a new CCRA chapter.',
    url: 'https://www.ccrassn.org/wp-content/uploads/2018/02/ccra_chapters_revision_23_may_11_1.pdf',
  },
  {
    title: 'Honors Policy',
    description: 'CCRA Policy Letter outlining the association\'s honors and awards criteria.',
    url: 'https://www.ccrassn.org/wp-content/uploads/2018/02/CCRA-Policy-Letter-4_8Oct2019.pdf',
  },
  {
    title: 'CCRA Policy 5 — SGM Paul Cockman Scholarship',
    description: 'Policy document governing the SGM Paul Cockman Scholarship program.',
    url: 'https://acrobat.adobe.com/id/urn:aaid:sc:US:82806e83-ed7b-45e3-828b-8fdc7595d29f',
  },
  {
    title: 'Order of the Dragon Form',
    description: 'Nomination and submission form for the Order of the Dragon.',
    url: 'https://acrobat.adobe.com/id/urn:aaid:sc:US:350d606f-0070-4ab7-bbbb-1240b6a6701f',
  },
  {
    title: 'Order of the Dragon Ceremonial Script',
    description: 'Official ceremonial script for Order of the Dragon induction ceremonies.',
    url: 'https://documentcloud.adobe.com/link/review?uri=urn:aaid:scds:US:690dc08f-afdf-47d5-9e9b-e16e08018f00',
  },
  {
    title: 'Honorable Order of the Dragon Listing',
    description: 'Roster of members inducted into the Honorable Order of the Dragon.',
    url: 'https://acrobat.adobe.com/id/urn:aaid:sc:US:3743e840-a495-4669-b5be-bfc792b9328d',
  },
  {
    title: 'Ancient Order of the Dragon Listing',
    description: 'Roster of members inducted into the Ancient Order of the Dragon.',
    url: 'https://acrobat.adobe.com/id/urn:aaid:sc:US:7f8c0bc9-513c-403b-8308-5d5b88a5a621',
  },
  {
    title: 'Legionnaire Order of the Dragon Listing',
    description: 'Roster of members inducted into the Legionnaire Order of the Dragon.',
    url: 'https://acrobat.adobe.com/id/urn:aaid:sc:US:0f49a038-d77a-4073-9970-73f01ac28231',
  },
  {
    title: 'Carol Ann Watson Award Listing',
    description: 'Listing of recipients of the Carol Ann Watson Award.',
    url: 'https://acrobat.adobe.com/id/urn:aaid:sc:US:beb83cef-01d0-47fb-90ff-b529c4c4a74a',
  },
  {
    title: 'Current Members',
    description: 'Current CCRA members and numbers.',
    url: '/ccra/documents/Website Membership 52626.pdf',
  },
];
---

<Layout title="Association Documents | CCRA">

  <!-- HERO -->
  <section style="background: var(--color-void); padding: 6rem 1.5rem 4rem; text-align: center;">
    <div style="max-width: 800px; margin: 0 auto;" class="fade-up">
      <p class="section-label" style="color: var(--color-dragon-gold); text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.875rem; margin-bottom: 0.75rem;">Membership</p>
      <h1 class="section-title" style="color: var(--color-ivory); font-size: 3rem; font-weight: 700; margin-bottom: 1rem;">Association Documents</h1>
      <div class="gold-line" style="width: 80px; height: 3px; background: var(--color-dragon-gold); margin: 0 auto 1.5rem;"></div>
      <p style="color: var(--color-ash); font-size: 1.125rem; line-height: 1.7; max-width: 640px; margin: 0 auto;">
        Official governing documents, charters, and policies of the Chemical Corps Regimental Association.
      </p>
    </div>
  </section>

  <!-- DOCUMENTS -->
  <section style="background: var(--color-bunker); padding: 5rem 1.5rem;">
    <div style="max-width: 960px; margin: 0 auto;" class="fade-up">

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); gap: 1.25rem;">
        {documents.map((doc, i) => (
          <a
            href={doc.url}
            target="_blank"
            rel="noopener noreferrer"
            style="display: flex; align-items: flex-start; gap: 1.25rem; padding: 1.5rem 1.75rem; background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 6px; text-decoration: none; transition: border-color 0.2s, box-shadow 0.2s;"
            onmouseover="this.style.borderColor='var(--color-dragon-gold)';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.3)'"
            onmouseout="this.style.borderColor='var(--color-gunmetal)';this.style.boxShadow='none'"
          >
            <!-- Doc number -->
            <div style="flex-shrink:0; width:42px; height:42px; background: rgba(197,163,85,0.08); border: 1px solid rgba(197,163,85,0.25); border-radius:4px; display:flex; align-items:center; justify-content:center;">
              <svg style="width:22px; height:22px; color:var(--color-dragon-gold);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>

            <div style="flex:1; min-width:0;">
              <div style="display:flex; align-items:center; justify-content:space-between; gap:0.5rem; margin-bottom:0.35rem;">
                <h3 style="color: var(--color-ivory); font-size: 0.95rem; font-weight: 700; margin: 0; line-height:1.3;">{doc.title}</h3>
                <svg style="flex-shrink:0; width:14px; height:14px; color:var(--color-dragon-gold); opacity:0.7;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </div>
              <p style="color: var(--color-ash); font-size: 0.825rem; line-height: 1.6; margin: 0;">{doc.description}</p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>

<style>
  @media (max-width: 640px) {
    div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
