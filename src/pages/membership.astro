---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Membership | CCRA">

  <!-- HERO -->
  <section style="background: var(--color-void); padding: 6rem 1.5rem 4rem; text-align: center;">
    <div style="max-width: 800px; margin: 0 auto;" class="fade-up">
      <p class="section-label" style="color: var(--color-dragon-gold); text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.875rem; margin-bottom: 0.75rem;">Membership</p>
      <h1 class="section-title" style="color: var(--color-ivory); font-size: 3rem; font-weight: 700; margin-bottom: 1rem;">Join the Dragon Soldiers</h1>
      <div class="gold-line" style="width: 80px; height: 3px; background: var(--color-dragon-gold); margin: 0 auto 1.5rem;"></div>
      <p style="color: var(--color-ash); font-size: 1.125rem; line-height: 1.7; max-width: 640px; margin: 0 auto;">
        Become a member of the Chemical Corps Regimental Association and join a proud community dedicated to preserving the heritage and supporting the future of the Chemical Corps.
      </p>
    </div>
  </section>

  <!-- ELIGIBILITY -->
  <section style="background: var(--color-bunker); padding: 5rem 1.5rem;">
    <div style="max-width: 900px; margin: 0 auto;" class="fade-up">
      <p class="section-label" style="color: var(--color-dragon-gold); text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.875rem; margin-bottom: 0.75rem; text-align: center;">Who Can Join</p>
      <h2 class="section-title" style="color: var(--color-ivory); font-size: 2rem; font-weight: 700; margin-bottom: 1rem; text-align: center;">Eligibility</h2>
      <div class="gold-line" style="width: 60px; height: 3px; background: var(--color-dragon-gold); margin: 0 auto 2rem;"></div>
      <div class="card-dark" style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 8px; padding: 2rem;">
        <p style="color: var(--color-bone); font-size: 1.05rem; line-height: 1.8;">
          Membership in the CCRA is open to <strong style="color: var(--color-ivory);">Active, Reserve Component, and National Guard service members</strong>;
          <strong style="color: var(--color-ivory);">Retired service members</strong>;
          <strong style="color: var(--color-ivory);">present and former Government civilian employees</strong>;
          <strong style="color: var(--color-ivory);">veterans</strong>;
          <strong style="color: var(--color-ivory);">cadets of the Service Academies and ROTC</strong>;
          and <strong style="color: var(--color-ivory);">friends and family of the Chemical Corps</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- INDIVIDUAL MEMBERSHIP -->
  <section style="background: var(--color-void); padding: 5rem 1.5rem;">
    <div style="max-width: 960px; margin: 0 auto;" class="fade-up">
      <p class="section-label" style="color: var(--color-dragon-gold); text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.875rem; margin-bottom: 0.75rem; text-align: center;">Individual</p>
      <h2 class="section-title" style="color: var(--color-ivory); font-size: 2rem; font-weight: 700; margin-bottom: 1rem; text-align: center;">Individual Membership</h2>
      <div class="gold-line" style="width: 60px; height: 3px; background: var(--color-dragon-gold); margin: 0 auto 2.5rem;"></div>

      <div style="overflow-x: auto; margin-bottom: 2.5rem;">
        <table style="width: 100%; border-collapse: collapse; min-width: 500px;">
          <thead>
            <tr style="border-bottom: 2px solid var(--color-dragon-gold);">
              <th style="text-align: left; padding: 1rem; color: var(--color-dragon-gold); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em;">Category</th>
              <th style="text-align: center; padding: 1rem; color: var(--color-dragon-gold); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em;">Annual</th>
              <th style="text-align: center; padding: 1rem; color: var(--color-dragon-gold); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em;">Lifetime</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--color-gunmetal);">
              <td style="padding: 1rem; color: var(--color-bone);">CBRN AIT Students</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$25</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$99</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-gunmetal); background: rgba(255,255,255,0.02);">
              <td style="padding: 1rem; color: var(--color-bone);">E-6 &amp; Below and CBOLC Students</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$25</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$125</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-gunmetal);">
              <td style="padding: 1rem; color: var(--color-bone);">All Others (Military, Civilians &amp; Retirees)</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$25</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$150</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="card-dark" style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 8px; padding: 1.75rem;">
        <h3 style="color: var(--color-dragon-gold); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Member Benefits</h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.75rem;">
          <li style="color: var(--color-bone); padding-left: 1.25rem; position: relative;">
            <span style="position: absolute; left: 0; color: var(--color-dragon-gold);">&#9670;</span> Letter of Acknowledgement
          </li>
          <li style="color: var(--color-bone); padding-left: 1.25rem; position: relative;">
            <span style="position: absolute; left: 0; color: var(--color-dragon-gold);">&#9670;</span> Membership Card
          </li>
          <li style="color: var(--color-bone); padding-left: 1.25rem; position: relative;">
            <span style="position: absolute; left: 0; color: var(--color-dragon-gold);">&#9670;</span> CCRA Decal
          </li>
          <li style="color: var(--color-bone); padding-left: 1.25rem; position: relative;">
            <span style="position: absolute; left: 0; color: var(--color-dragon-gold);">&#9670;</span> 10% Discount at Gift Shop
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CORPORATE MEMBERSHIP -->
  <section style="background: var(--color-bunker); padding: 5rem 1.5rem;">
    <div style="max-width: 960px; margin: 0 auto;" class="fade-up">
      <p class="section-label" style="color: var(--color-dragon-gold); text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.875rem; margin-bottom: 0.75rem; text-align: center;">Corporate</p>
      <h2 class="section-title" style="color: var(--color-ivory); font-size: 2rem; font-weight: 700; margin-bottom: 1rem; text-align: center;">Corporate Membership</h2>
      <div class="gold-line" style="width: 60px; height: 3px; background: var(--color-dragon-gold); margin: 0 auto 2.5rem;"></div>

      <div style="overflow-x: auto; margin-bottom: 2.5rem;">
        <table style="width: 100%; border-collapse: collapse; min-width: 500px;">
          <thead>
            <tr style="border-bottom: 2px solid var(--color-dragon-gold);">
              <th style="text-align: left; padding: 1rem; color: var(--color-dragon-gold); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em;">Category</th>
              <th style="text-align: center; padding: 1rem; color: var(--color-dragon-gold); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em;">Annual</th>
              <th style="text-align: center; padding: 1rem; color: var(--color-dragon-gold); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em;">Lifetime</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--color-gunmetal);">
              <td style="padding: 1rem; color: var(--color-bone);">Companies ≤49 Employees</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$250</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$2,000</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-gunmetal); background: rgba(255,255,255,0.02);">
              <td style="padding: 1rem; color: var(--color-bone);">Companies 50+ Employees</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$500</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$4,000</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-gunmetal);">
              <td style="padding: 1rem; color: var(--color-bone);">University</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$250</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$2,000</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-gunmetal); background: rgba(255,255,255,0.02);">
              <td style="padding: 1rem; color: var(--color-bone);">Government Entity</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$250</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$2,000</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-gunmetal);">
              <td style="padding: 1rem; color: var(--color-dragon-gold); font-weight: 600;">&#9733; Silver Corporate</td>
              <td style="padding: 1rem; color: var(--color-steel); text-align: center;">—</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$10,000</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-gunmetal); background: rgba(255,255,255,0.02);">
              <td style="padding: 1rem; color: var(--color-dragon-gold); font-weight: 600;">&#9733; Gold Corporate</td>
              <td style="padding: 1rem; color: var(--color-steel); text-align: center;">—</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$15,000</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--color-gunmetal);">
              <td style="padding: 1rem; color: var(--color-dragon-gold); font-weight: 600;">&#9733; Platinum Corporate</td>
              <td style="padding: 1rem; color: var(--color-steel); text-align: center;">—</td>
              <td style="padding: 1rem; color: var(--color-ivory); text-align: center; font-weight: 600;">$20,000</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="card-dark" style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 8px; padding: 1.75rem;">
        <h3 style="color: var(--color-dragon-gold); font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Corporate Benefits</h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.75rem;">
          <li style="color: var(--color-bone); padding-left: 1.25rem; position: relative;">
            <span style="position: absolute; left: 0; color: var(--color-dragon-gold);">&#9670;</span> Letter of Acknowledgement
          </li>
          <li style="color: var(--color-bone); padding-left: 1.25rem; position: relative;">
            <span style="position: absolute; left: 0; color: var(--color-dragon-gold);">&#9670;</span> Membership Certificate
          </li>
          <li style="color: var(--color-bone); padding-left: 1.25rem; position: relative;">
            <span style="position: absolute; left: 0; color: var(--color-dragon-gold);">&#9670;</span> CCRA Decal
          </li>
          <li style="color: var(--color-bone); padding-left: 1.25rem; position: relative;">
            <span style="position: absolute; left: 0; color: var(--color-dragon-gold);">&#9670;</span> Website Listing
          </li>
          <li style="color: var(--color-bone); padding-left: 1.25rem; position: relative;">
            <span style="position: absolute; left: 0; color: var(--color-dragon-gold);">&#9670;</span> Event Recognition
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: var(--color-void); padding: 5rem 1.5rem; text-align: center;">
    <div style="max-width: 600px; margin: 0 auto;" class="fade-up">
      <h2 class="section-title" style="color: var(--color-ivory); font-size: 2rem; font-weight: 700; margin-bottom: 1rem;">Ready to Join?</h2>
      <div class="gold-line" style="width: 60px; height: 3px; background: var(--color-dragon-gold); margin: 0 auto 1.5rem;"></div>
      <p style="color: var(--color-ash); font-size: 1.05rem; line-height: 1.7; margin-bottom: 2rem;">
        Become part of a legacy that spans over a century of service. Your membership directly supports the Chemical Corps community.
      </p>
      <a href="#" class="btn-solid" style="display: inline-block; background: var(--color-dragon-gold); color: var(--color-void); padding: 0.875rem 2.5rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; text-decoration: none; border-radius: 4px; font-size: 0.95rem;">
        Join Now
      </a>
    </div>
  </section>

</Layout>
