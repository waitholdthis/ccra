---
import Layout from '../layouts/Layout.astro';

const categories = [
  { name: "Donations", count: 1, url: "https://www.ccrassn.org/product-category/donations/", image: "giftshop/donations.jpg", desc: "Support the CCRA mission directly" },
  { name: "Sale", count: 10, url: "https://www.ccrassn.org/product-category/sale/", image: "giftshop/sale.jpg", desc: "Discounted items & special deals" },
  { name: "Accessories", count: 7, url: "https://www.ccrassn.org/product-category/accessories/", image: "giftshop/accessories.jpg", desc: "Keychains, lanyards & more" },
  { name: "Books", count: 2, url: "https://www.ccrassn.org/product-category/books/", image: "giftshop/books.jpg", desc: "Chemical Corps history & reference" },
  { name: "Coins", count: 8, url: "https://www.ccrassn.org/product-category/coins/", image: "giftshop/coins.jpg", desc: "Challenge coins & commemorative medallions" },
  { name: "Collectibles", count: 6, url: "https://www.ccrassn.org/product-category/collectibles/", image: "giftshop/collectibles.jpg", desc: "Limited edition & collectible items" },
  { name: "Drinkware", count: 4, url: "https://www.ccrassn.org/product-category/drinkware/", image: "giftshop/drinkware.jpg", desc: "Mugs, tumblers & glassware" },
  { name: "Flags/Blankets", count: 4, url: "https://www.ccrassn.org/product-category/flags-blankets/", image: "giftshop/flags-blankets.jpg", desc: "Flags, blankets & throws" },
  { name: "Golf", count: 6, url: "https://www.ccrassn.org/product-category/golf/", image: "giftshop/golf.jpg", desc: "Golf balls, tees & accessories" },
  { name: "Hats, Patches, Pins", count: 18, url: "https://www.ccrassn.org/product-category/hats/", image: "giftshop/hats-patches-pins.jpg", desc: "Headwear, unit patches & lapel pins" },
  { name: "Jewelry & Pins", count: 2, url: "https://www.ccrassn.org/product-category/jewelry-pins/", image: "giftshop/jewelry-pins.jpg", desc: "Rings, bracelets & fine pins" },
  { name: "Kids & Toys", count: 10, url: "https://www.ccrassn.org/product-category/kids-toys/", image: "giftshop/kids-toys.jpg", desc: "Items for young Dragon Soldiers" },
  { name: "Magnets & Stickers", count: 19, url: "https://www.ccrassn.org/product-category/magnets-stickers-patches/", image: "giftshop/magnets-stickers.jpg", desc: "Vehicle magnets, decals & stickers" },
  { name: "Novelty", count: 2, url: "https://www.ccrassn.org/product-category/novelty/", image: "giftshop/novelty.jpg", desc: "Fun & unique gift items" },
  { name: "Office", count: 4, url: "https://www.ccrassn.org/product-category/office/", image: "giftshop/office.jpg", desc: "Desk items, pens & office supplies" },
  { name: "Shirts", count: 9, url: "https://www.ccrassn.org/product-category/shirt/", image: "giftshop/shirts.jpg", desc: "T-shirts, polos & apparel" },
  { name: "Accouterments", count: 6, url: "https://www.ccrassn.org/product-category/accouterments/", image: "giftshop/accouterments.jpg", desc: "Military dress accessories" },
];

const assetBase = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<Layout title="Cathy Griffin Regimental Gift Shop" description="Shop official Chemical Corps merchandise — coins, apparel, collectibles, and more. All proceeds support CCRA programs and the Dragon Soldier legacy.">

  <!-- HERO -->
  <section style="background: var(--color-void); padding: 6rem 1.5rem 4rem; text-align: center;">
    <div style="max-width: 800px; margin: 0 auto;" class="fade-up">
      <p class="section-label" style="color: var(--color-dragon-gold); text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.875rem; margin-bottom: 0.75rem;">Official Merchandise</p>
      <h1 class="section-title" style="color: var(--color-ivory); font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem;">Cathy Griffin Regimental Gift Shop</h1>
      <div class="gold-line" style="width: 80px; height: 3px; background: var(--color-dragon-gold); margin: 0 auto 1.5rem;"></div>
      <p style="color: var(--color-ash); font-size: 1.125rem; line-height: 1.7; max-width: 640px; margin: 0 auto 2rem;">
        Authentic Chemical Corps merchandise — from challenge coins and apparel to collectibles and gifts. All proceeds support CCRA programs, scholarships, and the Dragon Soldier legacy.
      </p>
      <a href="https://www.ccrassn.org/giftshop/" target="_blank" rel="noopener" class="btn-solid" style="display: inline-flex; align-items: center; gap: 0.5rem;">
        Browse the Full Shop
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </section>

  <!-- CATEGORY GRID -->
  <section style="background: var(--color-bunker); padding: 5rem 1.5rem;">
    <div style="max-width: 1100px; margin: 0 auto;">
      <div class="fade-up" style="text-align: center; margin-bottom: 3rem;">
        <p class="section-label" style="color: var(--color-dragon-gold); text-transform: uppercase; letter-spacing: 0.15em; font-size: 0.8rem; margin-bottom: 0.5rem;">Browse by Category</p>
        <h2 style="color: var(--color-ivory); font-size: 1.75rem; font-weight: 700;">Shop Categories</h2>
      </div>

      <div class="fade-up" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.25rem;">
        {categories.map(cat => (
          <a
            href={cat.url}
            target="_blank"
            rel="noopener"
            class="shop-card"
            style="display: block; background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 10px; overflow: hidden; text-decoration: none; transition: all 0.3s ease;"
          >
            <div class="shop-card-image-wrap">
              <img src={`${assetBase}${cat.image}`} alt={`${cat.name} gift shop category`} loading="lazy" width="500" height="500" class="shop-card-image" />
            </div>
            <div style="padding: 1.25rem;">
              <h3 style="color: var(--color-ivory); font-size: 1rem; font-weight: 600; margin-bottom: 0.35rem; line-height: 1.3;">{cat.name}</h3>
              <p style="color: var(--color-ash); font-size: 0.8rem; line-height: 1.5; margin-bottom: 0.75rem;">{cat.desc}</p>
              <span style="color: var(--color-dragon-gold); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500;">{cat.count} {cat.count === 1 ? 'Item' : 'Items'}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SHOP INFO -->
  <section style="background: var(--color-void); padding: 5rem 1.5rem;">
    <div style="max-width: 960px; margin: 0 auto;" class="fade-up">
      <div style="display: grid; grid-template-columns: 1fr; gap: 2rem;" class="md-grid-2">
        <div class="card-dark" style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 8px; padding: 2.5rem;">
          <h3 style="color: var(--color-dragon-gold); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.75rem;">About the Gift Shop</h3>
          <div class="gold-line" style="width: 40px; height: 3px; background: var(--color-dragon-gold); margin-bottom: 1.25rem;"></div>
          <p style="color: var(--color-bone); line-height: 1.8; margin-bottom: 1rem;">
            The Cathy Griffin Regimental Gift Shop is the official source for Chemical Corps merchandise. Named in honor of <strong style="color: var(--color-ivory);">Cathy Griffin</strong>, whose dedicated service to the CCRA and the Dragon Soldier community helped build and sustain the association's programs.
          </p>
          <p style="color: var(--color-bone); line-height: 1.8;">
            Every purchase supports the CCRA's mission — funding scholarships, recognition programs, and initiatives that strengthen the Chemical Corps Regiment and its families.
          </p>
        </div>

        <div class="card-dark" style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 8px; padding: 2.5rem;">
          <h3 style="color: var(--color-dragon-gold); font-size: 1.25rem; font-weight: 700; margin-bottom: 0.75rem;">Ordering Information</h3>
          <div class="gold-line" style="width: 40px; height: 3px; background: var(--color-dragon-gold); margin-bottom: 1.25rem;"></div>
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div style="display: flex; align-items: flex-start; gap: 0.75rem;">
              <span style="color: var(--color-dragon-gold); font-size: 1rem; flex-shrink: 0;">📦</span>
              <p style="color: var(--color-bone); font-size: 0.9rem; line-height: 1.7;">Orders ship from Fort Leonard Wood, MO. Shipping costs are calculated at checkout.</p>
            </div>
            <div style="display: flex; align-items: flex-start; gap: 0.75rem;">
              <span style="color: var(--color-dragon-gold); font-size: 1rem; flex-shrink: 0;">💳</span>
              <p style="color: var(--color-bone); font-size: 0.9rem; line-height: 1.7;">Secure online payments accepted. All proceeds go to CCRA programs.</p>
            </div>
            <div style="display: flex; align-items: flex-start; gap: 0.75rem;">
              <span style="color: var(--color-dragon-gold); font-size: 1rem; flex-shrink: 0;">📞</span>
              <p style="color: var(--color-bone); font-size: 0.9rem; line-height: 1.7;">Questions? Contact <a href="mailto:ccramanager@embarqmail.com" style="color: var(--color-dragon-gold);">ccramanager@embarqmail.com</a> or call <a href="tel:5733290600" style="color: var(--color-dragon-gold);">573.329.0600</a></p>
            </div>
          </div>
        </div>
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="https://www.ccrassn.org/giftshop/" target="_blank" rel="noopener" class="btn-solid" style="display: inline-flex; align-items: center; gap: 0.5rem;">
          Visit the Gift Shop
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <style>
    .shop-card {
      position: relative;
    }
    .shop-card::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(135deg, rgba(197, 163, 85, 0.16), transparent 35%, transparent 70%, rgba(197, 163, 85, 0.08));
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .shop-card-image-wrap {
      aspect-ratio: 1 / 1;
      background: radial-gradient(circle at center, rgba(197, 163, 85, 0.08), rgba(0, 0, 0, 0.22));
      border-bottom: 1px solid var(--color-gunmetal);
      overflow: hidden;
    }
    .shop-card-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: saturate(0.95) contrast(1.04);
      transition: transform 0.35s ease, filter 0.35s ease;
    }
    .shop-card:hover {
      border-color: var(--color-dragon-gold) !important;
      transform: translateY(-3px);
      box-shadow: 0 14px 38px rgba(197, 163, 85, 0.12);
    }
    .shop-card:hover::after {
      opacity: 1;
    }
    .shop-card:hover .shop-card-image {
      transform: scale(1.045);
      filter: saturate(1.08) contrast(1.08);
    }
    .shop-card:hover h3 {
      color: var(--color-dragon-gold) !important;
    }
    .md-grid-2 {
      grid-template-columns: 1fr !important;
    }
    @media (min-width: 768px) {
      .md-grid-2 {
        grid-template-columns: 1fr 1fr !important;
      }
    }
  </style>

</Layout>

