---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Southeast Regional & Special Operations Chapter | CCRA" description="The Southeast Regional and Special Operations Chapter — Fort Bragg, NC. Established 16 January 2019. Preserving and promoting the history and traditions of the U.S. Army Chemical Corps.">

  <!-- ═══ HERO ═══ -->
  <section class="relative overflow-hidden" style="min-height: 480px; display: flex; align-items: center; justify-content: center;">
    <div class="absolute inset-0" style="background: var(--color-void);">
      <img
        src="/ccra/chapters/SERSO.jpg"
        alt="Southeast Regional & Special Operations Chapter"
        style="width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: 0.25;"
      />
    </div>
    <div class="hero-overlay absolute inset-0 z-10"></div>
    <div class="relative z-20 text-center px-6" style="max-width: 860px; margin: 0 auto; padding-top: 7rem; padding-bottom: 5rem;" class="fade-up">
      <!-- Chapter of Year badge -->
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(197,163,85,0.12); border: 1px solid var(--color-dragon-gold); border-radius: 2px; padding: 0.35rem 1rem; margin-bottom: 1.25rem;">
        <svg style="width:0.75rem;height:0.75rem;color:var(--color-dragon-gold);" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <span style="color: var(--color-dragon-gold); font-size: 0.6rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase;">2026 CCRA Chapter of the Year</span>
      </div>
      <p class="section-label" style="margin-bottom: 0.75rem;">Fort Bragg, North Carolina · Est. 16 January 2019</p>
      <h1 class="section-title fade-up" style="font-size: clamp(1.75rem, 4vw, 3rem); font-weight: 300; margin-bottom: 1rem; line-height: 1.2;">
        Southeast Regional &amp;<br/>Special Operations Chapter
      </h1>
      <div class="gold-line" style="width: 60px; margin: 1.5rem auto;"></div>
      <p style="color: var(--color-ash); font-size: 0.95rem; line-height: 1.8; max-width: 680px; margin: 0 auto;">
        Preserving and promoting the history and traditions of the U.S. Army Chemical Corps while supporting the Soldiers and Families of Fort Bragg.
      </p>
    </div>
  </section>

  <!-- ═══ MISSION & VISION ═══ -->
  <section style="background: var(--color-command); padding: 5rem 1.5rem; border-top: 1px solid var(--color-gunmetal);">
    <div style="max-width: 1060px; margin: 0 auto;">
      <div class="fade-up" style="text-align: center; margin-bottom: 3rem;">
        <p class="section-label" style="margin-bottom: 0.5rem;">Who We Are</p>
        <h2 class="section-title" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 300;">Mission &amp; Vision</h2>
        <div class="gold-line" style="width: 50px; margin: 1.25rem auto 0;"></div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;" class="mv-grid fade-up">
        <!-- Mission -->
        <div style="background: var(--color-bunker); border: 1px solid var(--color-gunmetal); border-top: 3px solid var(--color-dragon-gold); border-radius: 4px; padding: 2.25rem;">
          <p style="font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-dragon-gold); margin-bottom: 0.75rem;">Mission</p>
          <p style="color: var(--color-bone); font-size: 0.95rem; line-height: 1.85; font-style: italic;">
            "To preserve and promote the history and traditions of the U.S. Army Chemical Corps; while supporting the Soldiers and Families of the Chapter by maintaining the Chapter Legacy, Enabling Mentorship, Networking, Professional Development, and Providing Community Outreach to the Fort Bragg Community."
          </p>
        </div>
        <!-- Vision -->
        <div style="background: var(--color-bunker); border: 1px solid var(--color-gunmetal); border-top: 3px solid var(--color-dragon-gold); border-radius: 4px; padding: 2.25rem;">
          <p style="font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--color-dragon-gold); margin-bottom: 0.75rem;">Vision</p>
          <p style="color: var(--color-bone); font-size: 0.95rem; line-height: 1.85; font-style: italic;">
            "To be the premier private organization on Fort Bragg which is fully aligned with the U.S. Army's Chemical Corps Regimental Association and recognized for supporting Fort Bragg Soldiers and Families."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CORE VALUES ═══ -->
  <section style="background: var(--color-void); padding: 5rem 1.5rem;">
    <div style="max-width: 1060px; margin: 0 auto;">
      <div class="fade-up" style="text-align: center; margin-bottom: 3rem;">
        <p class="section-label" style="margin-bottom: 0.5rem;">What We Stand For</p>
        <h2 class="section-title" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 300;">Core Values</h2>
        <div class="gold-line" style="width: 50px; margin: 1.25rem auto 0;"></div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 1.25rem;" class="fade-up">
        <div style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 4px; padding: 1.75rem; position: relative; overflow: hidden;">
          <div style="position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: linear-gradient(90deg, var(--color-dragon-gold), transparent);"></div>
          <p style="color: var(--color-dragon-gold); font-size: 2rem; font-weight: 700; line-height: 1; margin-bottom: 0.75rem;">01</p>
          <p style="color: var(--color-bone); font-size: 0.9rem; line-height: 1.7;">Commitment to our Nation, the Chemical Regiment, and our Fort Bragg Community</p>
        </div>
        <div style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 4px; padding: 1.75rem; position: relative; overflow: hidden;">
          <div style="position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: linear-gradient(90deg, var(--color-dragon-gold), transparent);"></div>
          <p style="color: var(--color-dragon-gold); font-size: 2rem; font-weight: 700; line-height: 1; margin-bottom: 0.75rem;">02</p>
          <p style="color: var(--color-bone); font-size: 0.9rem; line-height: 1.7;">Brotherhood and camaraderie, friendship, and bond of the CBRN professional community</p>
        </div>
        <div style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 4px; padding: 1.75rem; position: relative; overflow: hidden;">
          <div style="position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: linear-gradient(90deg, var(--color-dragon-gold), transparent);"></div>
          <p style="color: var(--color-dragon-gold); font-size: 2rem; font-weight: 700; line-height: 1; margin-bottom: 0.75rem;">03</p>
          <p style="color: var(--color-bone); font-size: 0.9rem; line-height: 1.7;">Responsible Service</p>
        </div>
        <div style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 4px; padding: 1.75rem; position: relative; overflow: hidden;">
          <div style="position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: linear-gradient(90deg, var(--color-dragon-gold), transparent);"></div>
          <p style="color: var(--color-dragon-gold); font-size: 2rem; font-weight: 700; line-height: 1; margin-bottom: 0.75rem;">04</p>
          <p style="color: var(--color-bone); font-size: 0.9rem; line-height: 1.7;">Network of Committed Professionals</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ AIMS & PURPOSES ═══ -->
  <section style="background: var(--color-command); padding: 5rem 1.5rem;">
    <div style="max-width: 1060px; margin: 0 auto;">
      <div class="fade-up" style="text-align: center; margin-bottom: 3rem;">
        <p class="section-label" style="margin-bottom: 0.5rem;">Chapter Charter</p>
        <h2 class="section-title" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 300;">Aims &amp; Purposes</h2>
        <div class="gold-line" style="width: 50px; margin: 1.25rem auto 0;"></div>
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;" class="aims-grid fade-up">
        {[
          "Establish a permanent organization that will further develop the common bond existing between all Dragon Soldiers who served on Fort Bragg.",
          "Foster appreciation for and study of the history and traditions of the United States Army Chemical Corps and understanding of their historical roles and contribution to the development and defense of the nation.",
          "Maintain records and publish the history and achievements of Fort Bragg CBRN Soldiers.",
          "Maintain contact with all partners who have become disabled in the service of their Country and provide educational opportunities to their families.",
          "Provide assistance and service when possible in matters pertaining to Veterans benefits.",
          "Encourage the Chemical, Biological, Nuclear, and Radiological (CBRN) aspect of national defense.",
          "Provide administrative and financial support to Dragon Soldiers for educational and scientific purposes, including an annual contribution to the Education Fund.",
          "Provide support mechanisms for our Dragon Soldiers and their Families on Fort Bragg.",
          "Recognize individuals and organizations that have contributed to the skill and professionalism of the Chemical Corps.",
          "Conduct meetings, outings, and other activities to promote, educate, and organize other means of support to the Chapter.",
          "Engage in or sponsor historical research and cooperate with accredited educational institutions, veterans chapters, and other organizations in furtherance of its objectives.",
          "Support other organizations, private or public, which have similar objectives.",
        ].map((aim, i) => (
          <div style="display: flex; gap: 1rem; padding: 1rem 1.25rem; background: var(--color-bunker); border: 1px solid var(--color-gunmetal); border-radius: 4px; align-items: flex-start;">
            <span style="flex-shrink: 0; color: var(--color-dragon-gold); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.08em; margin-top: 0.2rem;">{String(i + 1).padStart(2, '0')}</span>
            <p style="color: var(--color-ash); font-size: 0.85rem; line-height: 1.7; margin: 0;">{aim}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ LINES OF EFFORT ═══ -->
  <section style="background: var(--color-void); padding: 5rem 1.5rem;">
    <div style="max-width: 1060px; margin: 0 auto;">
      <div class="fade-up" style="text-align: center; margin-bottom: 3rem;">
        <p class="section-label" style="margin-bottom: 0.5rem;">How We Operate</p>
        <h2 class="section-title" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 300;">Lines of Effort</h2>
        <div class="gold-line" style="width: 50px; margin: 1.25rem auto 0;"></div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem;" class="fade-up">

        <!-- Mentorship -->
        <div style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 4px; padding: 2rem;">
          <div style="width: 40px; height: 40px; background: rgba(197,163,85,0.1); border: 1px solid rgba(197,163,85,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
            <svg width="18" height="18" fill="none" stroke="var(--color-dragon-gold)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 style="color: var(--color-ivory); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Mentorship &amp; Professional Development</h3>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Execute focused Soldier and Leader Professional Development Series</li>
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Facilitate formal Mentee/Mentor relationships</li>
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Prepare Mentees to take advantage of mentorship opportunities</li>
          </ul>
        </div>

        <!-- Networking -->
        <div style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 4px; padding: 2rem;">
          <div style="width: 40px; height: 40px; background: rgba(197,163,85,0.1); border: 1px solid rgba(197,163,85,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
            <svg width="18" height="18" fill="none" stroke="var(--color-dragon-gold)" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          </div>
          <h3 style="color: var(--color-ivory); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Networking</h3>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Develop the common bond between all Dragon Soldiers at Fort Bragg</li>
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Gain exposure to keep expertise and skill-building current</li>
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Gain Senior Leader involvement and engagement</li>
          </ul>
        </div>

        <!-- Community -->
        <div style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 4px; padding: 2rem;">
          <div style="width: 40px; height: 40px; background: rgba(197,163,85,0.1); border: 1px solid rgba(197,163,85,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
            <svg width="18" height="18" fill="none" stroke="var(--color-dragon-gold)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 style="color: var(--color-ivory); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Community Involvement &amp; Outreach</h3>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Establish community partnerships on Fort Bragg</li>
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Help to build up a caring community</li>
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Foster and develop outreach activities on Fort Bragg</li>
          </ul>
        </div>

        <!-- Legacy -->
        <div style="background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 4px; padding: 2rem;">
          <div style="width: 40px; height: 40px; background: rgba(197,163,85,0.1); border: 1px solid rgba(197,163,85,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;">
            <svg width="18" height="18" fill="none" stroke="var(--color-dragon-gold)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 style="color: var(--color-ivory); font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Chapter Legacy</h3>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem;">
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Maintain records and publish the history and achievements of the Chapter</li>
            <li style="color: var(--color-ash); font-size: 0.82rem; line-height: 1.6; padding-left: 1rem; position: relative;"><span style="position:absolute;left:0;color:var(--color-dragon-gold);">◆</span>Maintain contact with partners who became disabled in service of their Country</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ BOARD MEMBERS ═══ -->
  <section style="background: var(--color-command); padding: 5rem 1.5rem;">
    <div style="max-width: 1060px; margin: 0 auto;">
      <div class="fade-up" style="text-align: center; margin-bottom: 3rem;">
        <p class="section-label" style="margin-bottom: 0.5rem;">Chapter Leadership</p>
        <h2 class="section-title" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 300;">Active Board Members</h2>
        <div class="gold-line" style="width: 50px; margin: 1.25rem auto 0;"></div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem;" class="fade-up">

        <div style="background: var(--color-bunker); border: 1px solid var(--color-gunmetal); border-left: 3px solid var(--color-dragon-gold); border-radius: 0 4px 4px 0; padding: 1.25rem 1.5rem;">
          <p style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.35rem;">President</p>
          <p style="color: var(--color-ivory); font-size: 1rem; font-weight: 600;">SGM Jeffery D. Howard</p>
        </div>

        <div style="background: var(--color-bunker); border: 1px solid var(--color-gunmetal); border-left: 3px solid var(--color-dragon-gold); border-radius: 0 4px 4px 0; padding: 1.25rem 1.5rem;">
          <p style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.35rem;">Vice President</p>
          <p style="color: var(--color-ivory); font-size: 1rem; font-weight: 600;">SGM Ricky Sierra</p>
        </div>

        <div style="background: var(--color-bunker); border: 1px solid var(--color-gunmetal); border-left: 3px solid var(--color-dragon-gold); border-radius: 0 4px 4px 0; padding: 1.25rem 1.5rem;">
          <p style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.35rem;">Secretary</p>
          <p style="color: var(--color-ivory); font-size: 1rem; font-weight: 600;">Mr. Dave Dunlap</p>
        </div>

        <div style="background: var(--color-bunker); border: 1px solid var(--color-gunmetal); border-left: 3px solid var(--color-dragon-gold); border-radius: 0 4px 4px 0; padding: 1.25rem 1.5rem;">
          <p style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.35rem;">Treasurer</p>
          <p style="color: var(--color-ivory); font-size: 1rem; font-weight: 600;">1SG Jeremy Lindstrom</p>
          <p style="color: var(--color-ivory); font-size: 1rem; font-weight: 600; margin-top: 0.25rem;">1LT Isabel Restrepo</p>
        </div>

        <div style="background: var(--color-bunker); border: 1px solid var(--color-gunmetal); border-left: 3px solid var(--color-dragon-gold); border-radius: 0 4px 4px 0; padding: 1.25rem 1.5rem;">
          <p style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.35rem;">Technical Director</p>
          <p style="color: var(--color-ivory); font-size: 1rem; font-weight: 600;">COL(R) Andy Herbst</p>
        </div>

        <div style="background: var(--color-bunker); border: 1px solid var(--color-gunmetal); border-left: 3px solid var(--color-dragon-gold); border-radius: 0 4px 4px 0; padding: 1.25rem 1.5rem;">
          <p style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.35rem;">Programmers</p>
          <p style="color: var(--color-ivory); font-size: 0.9rem; line-height: 1.8;">
            1LT Mike Riley · SFC Trey Brown<br/>CPT Thomas Bond · CPT Ben Amenu
          </p>
        </div>

        <div style="background: var(--color-bunker); border: 1px solid var(--color-gunmetal); border-left: 3px solid var(--color-dragon-gold); border-radius: 0 4px 4px 0; padding: 1.25rem 1.5rem;">
          <p style="color: var(--color-dragon-gold); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 0.35rem;">Webmaster</p>
          <p style="color: var(--color-ivory); font-size: 1rem; font-weight: 600;">CW3 Parker Tootil</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ UPCOMING EVENTS ═══ -->
  <section style="background: var(--color-void); padding: 5rem 1.5rem;">
    <div style="max-width: 1060px; margin: 0 auto;">
      <div class="fade-up" style="text-align: center; margin-bottom: 3rem;">
        <p class="section-label" style="margin-bottom: 0.5rem;">Regimental Week 2026</p>
        <h2 class="section-title" style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 300;">Upcoming Events</h2>
        <div class="gold-line" style="width: 50px; margin: 1.25rem auto 0;"></div>
      </div>
      <div style="display: flex; flex-direction: column; gap: 0.75rem; max-width: 760px; margin: 0 auto;" class="fade-up">

        <div style="display: flex; gap: 1.5rem; align-items: center; background: var(--color-command); border: 1px solid var(--color-gunmetal); border-radius: 4px; padding: 1.25rem 1.5rem;">
          <div style="flex-shrink: 0; text-align: center; background: rgba(197,163,85,0.08); border: 1px solid rgba(197,163,85,0.25); border-radius: 4px; padding: 0.6rem 1rem; min-width: 64px;">
            <p style="color: var(--color-dragon-gold); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.12em;">Jun</p>
            <p style="color: var(--color-ivory); font-size: 1.5rem; font-weight: 700; line-height: 1;">3</p>
          </div>
          <div>
            <p style="color: var(--color-ivory); font-size: 0.95rem; font-weight: 600; margin-bottom: 0.2rem;">Chemical Corps Regimental Run</p>
